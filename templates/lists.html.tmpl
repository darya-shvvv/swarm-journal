],'Library':['📚','#1A5276'],'Amphitheater':['🎭','#8E44AD'],'Music Venue':['🎸','#8E44AD'],'Opera House':['🎭','#6C3483'],'Attraction':['⭐','#D4A017'],'Zoo':['🦁','#D4A017'],'Aquarium':['🐠','#2980B9'],'Casino':['🎲','#C0392B'],'Escape Room':['🔐','#8E44AD'],'Event Space':['🎪','#C0392B'],'Church':['⛪','#7D3C98'],'Mosque':['🕌','#117A65'],'Temple':['🛕','#B9770E'],'Monastery':['🙏','#6E2F1A'],'Synagogue':['✡️','#1A5276'],'Shrine':['⛩️','#C0392B'],'Buddhist Temple':['☸️','#D4A017'],'Hindu Temple':['🛕','#E67E22'],'Shopping Mall':['🛍️','#E91E63'],'Department Store':['🏬','#C0392B'],'Clothing Store':['👔','#8E44AD'],'Shoe Store':['👟','#D35400'],'Electronics Store':['💻','#2471A3'],'Mobile Phone Store':['📱','#2E86C1'],'Bookstore':['📚','#1A5276'],'Furniture and Home Store':['🛋️','#784212'],'Cosmetics Store':['💄','#F06292'],'Bicycle Store':['🚲','#27AE60'],'Big Box Store':['📦','#7F8C8D'],'Flea Market':['🏷️','#D35400'],'Hardware Store':['🔧','#7F8C8D'],'Miscellaneous Store':['🏪','#E67E22'],'Souvenir Store':['🛍️','#D4A017'],'Gift Store':['🎁','#E91E8C'],'Jewelry Store':['💍','#D4A017'],'Antique Store':['🏺','#D4A017'],'Outdoor Supply Store':['⛺','#27AE60'],'Sporting Goods Retail':['⚽','#27AE60'],'Fruit and Vegetable Store':['🥦','#27AE60'],'Butcher':['🥩','#C0392B'],'Fish Market':['🐟','#2980B9'],'Pharmacy':['💊','#27AE60'],'Drugstore':['💊','#27AE60'],'Health Food Store':['🥗','#1E8449'],'Gym':['💪','#E74C3C'],'Bath House':['♨️','#1ABC9C'],'Spa':['💆','#1ABC9C'],'Medical Center':['🏥','#E74C3C'],'Hospital':['🏥','#E74C3C'],'Yoga Studio':['🧘','#27AE60'],'Hair Salon':['✂️','#F06292'],'Swimming Pool':['🏊','#2980B9'],'Sauna':['♨️','#E74C3C'],'Bank':['🏦','#1A5276'],'Office':['🏢','#2C3E50'],'Post Office':['📮','#E74C3C'],'Police Station':['👮','#2471A3'],'City Hall':['🏛️','#1A5276'],'Government Building':['🏛️','#154360'],'University':['🎓','#154360'],'Business Center':['🏢','#2C3E50'],'Coworking Space':['💻','#2C3E50'],'Embassy or Consulate':['🏛️','#1A5276'],'Chinese Restaurant':['🥢','#C0392B'],'Japanese Restaurant':['🍱','#C0392B'],'Korean Restaurant':['🍚','#E74C3C'],'Vietnamese Restaurant':['🍜','#27AE60'],'Thai Restaurant':['🍛','#F39C12'],'Indian Restaurant':['🍛','#E67E22'],'Turkish Restaurant':['🌯','#C0392B'],'Greek Restaurant':['🫒','#27AE60'],'French Restaurant':['🥐','#2980B9'],'Spanish Restaurant':['🥘','#E74C3C'],'German Restaurant':['🍺','#C8860A'],'Mexican Restaurant':['🌮','#27AE60'],'American Restaurant':['🍔','#E67E22'],'Middle Eastern Restaurant':['🧆','#D35400'],'Russian Restaurant':['🥟','#C0392B'],'Ukrainian Restaurant':['🌻','#F39C12'],'Belarusian Restaurant':['🥟','#27AE60'],'Eastern European Restaurant':['🍲','#C0392B'],'Diner':['🍳','#E67E22'],'Bistro':['🍽️','#C0392B'],'Dessert Shop':['🍰','#F06292'],'Ice Cream Parlor':['🍦','#F06292'],'Pastry Shop':['🥐','#C8860A'],'Coffee Roaster':['☕','#4A235A'],'Cafe, Coffee, and Tea House':['☕','#6F4E37'],'Blini House':['🫓','#C8860A'],'Pelmeni House':['🥟','#C8860A'],'Dumpling Restaurant':['🥟','#E67E22'],'Ramen Restaurant':['🍜','#E74C3C'],'Sushi Restaurant':['🍣','#C0392B'],'Steak House':['🥩','#922B21'],'Steakhouse':['🥩','#922B21'],'Seafood Restaurant':['🦐','#2980B9'],'Food Truck':['🚚','#E67E22'],'BBQ Joint':['🔥','#C0392B'],'Vegan and Vegetarian Restaurant':['🥦','#27AE60'],'Breakfast Spot':['🥞','#F39C12'],'Tea Room':['🫖','#27AE60'],'Bubble Tea Shop':['🧋','#8E44AD'],'Hot Dog Joint':['🌭','#E67E22'],'Taco Restaurant':['🌮','#27AE60'],'Trattoria':['🍝','#C0392B'],'Deli':['🥪','#D4A017'],'Sandwich Spot':['🥪','#D4A017'],'Shawarma Restaurant':['🌯','#D35400'],'Doner Restaurant':['🌯','#E67E22'],'Romanian Restaurant':['🥘','#C0392B'],'Polish Restaurant':['🥟','#C0392B'],'Modern European Restaurant':['🍽️','#C0392B'],'Asian Restaurant':['🥢','#C0392B'],'Noodle Restaurant':['🍜','#E67E22'],'Bagel Shop':['🥯','#C8860A'],'Comfort Food Restaurant':['🥘','#D4A017'],'Winery':['🍇','#922B21'],'Christmas Market':['🎄','#27AE60']};
function catIcon(cat){const e=CAT_ICON[cat||''];return e?{em:e[0],bg:e[1]}:{em:'📍',bg:'#4a5270'};}

const RATING_EMOJI={'like':'❤️','neutral':'😐','dislike':'💔'};

// ── List rendering ────────────────────────────────────────────────────────────
let _sortMode = 'updated';
let filteredLists = [];
let selIdx = -1;
let map = null, mapMarkers = [];

function _maxVisitTs(lst){
  return Math.max(0,...(lst.venues||[]).map(v=>v.lts||0));
}

function _applySortFilter(q){
  const lq = (q||'').toLowerCase();
  let base = lq ? LISTS.filter(l=>(l.name||'').toLowerCase().includes(lq)) : LISTS.slice();
  if(_sortMode==='az'){
    base.sort((a,b)=>(a.name||'').localeCompare(b.name||''));
  } else if(_sortMode==='updated'){
    base.sort((a,b)=>(b.updatedAt||0)-(a.updatedAt||0));
  } else if(_sortMode==='visited'){
    base.sort((a,b)=>_maxVisitTs(b)-_maxVisitTs(a));
  }
  filteredLists = base;
}

function setSort(mode){
  _sortMode = mode;
  document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));
  const map2={'az':'srtAZ','updated':'srtUpdated','visited':'srtVisited'};
  const btn=document.getElementById(map2[mode]);
  if(btn) btn.classList.add('active');
  _applySortFilter(document.getElementById('listSearch').value);
  renderListItems();
}

function renderListItems(){
  const el = document.getElementById('listsScroll');
  if(!filteredLists.length){
    el.innerHTML = '<div class="lists-empty">No lists found</div>';
    return;
  }
  el.innerHTML = filteredLists.map((lst, fi)=>{
    const origIdx = LISTS.indexOf(lst);
    const thumb = lst.cover
      ? `<img class="li-thumb" src="${esc(lst.cover)}" alt="" loading="lazy" onerror="this.style.display='none'">`
      : `<div class="li-thumb-ph">📋</div>`;
    const sel = origIdx === selIdx ? ' sel' : '';
    return `<div class="list-item${sel}" onclick="selectList(${origIdx})">${thumb}<div class="li-body"><div class="li-name">${esc(lst.name)}</div><div class="li-count">${lst.count} venues</div></div></div>`;
  }).join('');
}

function filterLists(q){
  _applySortFilter(q);
  renderListItems();
}

function selectList(idx){
  selIdx = idx;
  renderListItems();
  const lst = LISTS[idx];
  if(!lst) return;

  document.getElementById('detailEmpty').style.display = 'none';
  const dc = document.getElementById('detailContent');
  dc.style.display = 'flex';
  dc.style.flexDirection = 'column';
  dc.style.overflow = 'hidden';
  dc.style.flex = '1';

  // Header
  const visitedCount = (lst.venues||[]).filter(v=>v.visited).length;
  const withCoords = (lst.venues||[]).filter(v=>v.lat&&v.lng).length;
  document.getElementById('detailHeader').innerHTML = `
    <div class="dh-name">${lst.url?`<a href="${esc(lst.url)}" target="_blank" rel="noopener">${esc(lst.name)}</a>`:esc(lst.name)}</div>
    <div class="dh-meta">
      <span>${lst.count} venues</span>
      <span class="dh-visited">✓ ${visitedCount} visited</span>
      ${withCoords?`<span>${withCoords} on map</span>`:''}
    </div>`;

  // Map
  const mapEl = document.getElementById('map');
  if(withCoords){
    mapEl.style.display = 'block';
    if(!map){
      map = L.map('map',{preferCanvas:true}).setView([30,15],2);
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
    }
    mapMarkers.forEach(m=>map.removeLayer(m));
    mapMarkers = [];
    const bounds = [];
    (lst.venues||[]).forEach((v,vi)=>{
      if(!v.lat||!v.lng) return;
      const col = v.visited ? '#4ec9b0' : '#e8b86d';
      const m = L.circleMarker([parseFloat(v.lat),parseFloat(v.lng)],{radius:5,fillColor:col,fillOpacity:.75,color:col,weight:1}).addTo(map);
      const loc = [v.nci||v.city,v.nc||v.country].filter(Boolean).join(', ');
      m.bindPopup(`<b>${esc(v.n||'')}</b><br><span style="font-size:.75rem;color:#9ca3af;">${esc(loc)}</span>`,{maxWidth:200});
      mapMarkers.push(m);
      bounds.push([parseFloat(v.lat),parseFloat(v.lng)]);
    });
    if(bounds.length) map.fitBounds(bounds,{padding:[20,20],maxZoom:14});
    setTimeout(()=>map.invalidateSize(),50);
  } else {
    mapEl.style.display = 'none';
  }

  // Venue cards
  document.getElementById('venuesScroll').innerHTML = (lst.venues||[]).map((v,vi)=>{
    const{em,bg}=catIcon(v.cat||'');
    const closedBadge = v.cl ? '<span class="vc-closed">CLOSED</span>' : '';
    const visitBadge = v.visited ? '<span class="vc-visited">✓ visited</span>' : '<span class="vc-saved">saved</span>';
    const ratingBadge = v.r ? `<span class="vc-rating">${RATING_EMOJI[v.r]||''}</span>` : '';
    const nameLabel = v.u ? `<a href="${esc(v.u)}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(v.n||'Unknown venue')}</a>` : esc(v.n||'Unknown venue');
    const flag = (v.nc||v.country) ? flagHtml(v.nc||v.country) : '';
    const locParts = [v.nci||v.city, v.nc||v.country].filter(Boolean);
    const locStr = esc(locParts.join(', '));
    const locHtml = (flag||locStr)
      ? `<span class="vc-sep">·</span><span class="vc-loc">${flag}${locStr?`<span class="vc-loc-text">${locStr}</span>`:''}</span>`
      : '';
    const dateHtml = v.ld ? `<span class="vc-date">${v.ld}</span>` : '';
    return `<div class="vcard" id="lvc_${vi}" onclick="selectVenue(${vi},${idx})">
      <div class="vc-head">
        <div class="vc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
        <div class="vc-name">${nameLabel}${visitBadge}${closedBadge}</div>
        ${ratingBadge}
      </div>
      <div class="vc-foot">
        <span class="vc-cat">${esc(v.cat||'')}</span>
        ${locHtml}${dateHtml}
      </div>
    </div>`;
  }).join('');
}

function selectVenue(vi, listIdx){
  document.querySelectorAll('.vcard.sel').forEach(el=>el.classList.remove('sel'));
  const el = document.getElementById('lvc_'+vi);
  if(el){el.classList.add('sel');}
  if(!map) return;
  const m = mapMarkers[vi];
  if(m){
    map.panTo(m.getLatLng(),{animate:true});
    m.openPopup();
  }
}

_applySortFilter('');
renderListItems();
if(filteredLists.length) selectList(LISTS.indexOf(filteredLists[0]));
</script>
<script>
function gsOpen(){document.getElementById('gsOverlay').classList.add('open');document.getElementById('gsInput').focus();}
function gsClose(){document.getElementById('gsOverlay').classList.remove('open');}
document.getElementById('gsInput').addEventListener('keydown',function(e){if(e.key==='Enter'&&this.value.trim()){location.href='search.html?q='+encodeURIComponent(this.value.trim());}if(e.key==='Escape')gsClose();});
document.addEventListener('keydown',function(e){if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();gsOpen();}if(e.key==='Escape'&&document.getElementById('gsOverlay').classList.contains('open'))gsClose();});
</script>

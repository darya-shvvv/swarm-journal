<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>My Lists — Check-in Journal</title>
<meta name="description" content="Foursquare lists — city guides, saved places, and themed collections across 60+ countries.">
<link rel="canonical" href="https://4sq.pages.dev/lists.html">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Check-in Journal">
<meta property="og:title" content="My Lists — Check-in Journal">
<meta property="og:description" content="Foursquare lists — city guides, saved places, and themed collections across 60+ countries.">
<meta property="og:url" content="https://4sq.pages.dev/lists.html">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="My Lists — Check-in Journal">
<meta name="twitter:description" content="Foursquare lists — city guides, saved places, and themed collections across 60+ countries.">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600&family=DM+Mono&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/6.6.6/css/flag-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
body.light{--bg:#ddd8cf;--card:#f0ece3;--card2:#e5e0d7;--border:#aaa49a;--gold:#7a3e00;--teal:#155c58;--muted:#54576a;--text:#15172a;--text2:#373b58;}
body.light header{background:linear-gradient(160deg,#d6d1c8 0%,#dedad1 70%);}
body.light .side-nav{background:rgba(220,215,208,0.97);}
body.light .side-nav a:hover,body.light .side-nav button:hover{background:rgba(0,0,0,.08);}
body.light .heatmap-tooltip,body.light .map-status{background:rgba(220,215,208,0.97);}
body.light .card{box-shadow:0 2px 8px rgba(0,0,0,.10);}
body.light a{color:var(--teal);}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;}
.page{display:flex;flex-direction:column;height:100vh;}

/* ── Top nav ── */
.topnav{display:flex;align-items:center;gap:20px;padding:14px 16px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;}
.topnav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--gold);text-decoration:none;margin-right:4px;white-space:nowrap;}
.topnav-logo:hover{opacity:.85;}
.topnav a{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);text-decoration:none;transition:color .2s;}
.topnav a:hover{color:var(--gold);}
.topnav-current{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--text);}
.page-insight{padding:7px 16px;font-family:'DM Sans',sans-serif;font-size:.78rem;color:var(--muted);font-style:italic;border-bottom:1px solid var(--border);background:var(--card);line-height:1.5;flex-shrink:0;}
.gs-btn{font-family:'DM Mono',monospace;font-size:.60rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:7px 14px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.gs-btn:hover{border-color:var(--gold);color:var(--gold);}
.gs-btn kbd{font-family:'DM Mono',monospace;font-size:.52rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:1px 5px;letter-spacing:0;}
@media(max-width:520px){.gs-btn kbd{display:none;}}
.gs-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:10000;backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding-top:16vh;}.gs-overlay.open{display:flex;}
.gs-modal{background:var(--card);border:1px solid var(--border);border-radius:14px;width:min(560px,92vw);overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.7);}
.gs-input-wrap{display:flex;align-items:center;gap:10px;padding:14px 18px;}
.gs-icon{font-size:1rem;color:var(--muted);}
.gs-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.95rem;}
.gs-input::placeholder{color:var(--muted);}
.gs-esc-hint{font-family:'DM Mono',monospace;font-size:.52rem;color:var(--muted);background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:2px 6px;cursor:pointer;flex-shrink:0;}
.side-nav{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:4000;display:flex;flex-direction:column;gap:0;background:rgba(18,21,31,0.92);border:1px solid var(--border);border-right:none;border-radius:10px 0 0 10px;backdrop-filter:blur(10px);overflow:hidden;}
.side-nav a,.side-nav button{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;width:52px;padding:10px 4px;border:none;background:none;cursor:pointer;color:var(--muted);text-decoration:none;transition:color .15s,background .15s;-webkit-tap-highlight-color:transparent;}
.side-nav a:hover,.side-nav button:hover{background:rgba(255,255,255,.06);color:var(--text);}
.side-nav a.active,.side-nav button.active{color:var(--gold);}
.side-nav .sn-icon{font-size:.95rem;line-height:1;display:inline-block;transition:transform .15s;}
.side-nav a:hover .sn-icon,.side-nav button:hover .sn-icon{transform:scale(1.28);}
.side-nav .sn-lbl{font-family:'DM Mono',monospace;font-size:.42rem;text-transform:uppercase;letter-spacing:.05em;line-height:1;white-space:nowrap;}
.side-nav .sn-sep{width:32px;height:1px;background:var(--border);margin:2px auto;}
.side-nav .sn-sep--pages{width:36px;height:2px;background:var(--border);margin:3px auto;border-radius:1px;}
@media(max-width:900px){.side-nav{display:none;}}

/* ── Layout ── */
.content{display:flex;flex:1;overflow:hidden;}

/* ── Left panel: list of lists ── */
.lists-panel{width:300px;flex-shrink:0;border-right:1px solid var(--border);display:flex;flex-direction:column;background:var(--card);}
.lists-search-wrap{padding:8px 10px;border-bottom:1px solid var(--border);flex-shrink:0;}
.lists-search{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:6px 10px;color:var(--text);font-size:.73rem;outline:none;}
.lists-search:focus{border-color:var(--gold);}
.sort-bar{display:flex;gap:4px;padding:6px 8px;border-bottom:1px solid var(--border);flex-shrink:0;}
.sort-btn{font-family:'DM Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.07em;padding:4px 8px;border-radius:5px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;transition:all .15s;white-space:nowrap;}
.sort-btn:hover{border-color:var(--gold);color:var(--gold);}
.sort-btn.active{border-color:var(--gold);color:var(--gold);background:rgba(232,184,109,.08);}
.lists-scroll{flex:1;overflow-y:auto;padding:6px;}
.lists-scroll::-webkit-scrollbar{width:3px;}
.lists-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.list-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;transition:background .12s;border:1px solid transparent;}
.list-item:hover{background:rgba(255,255,255,.04);}
.list-item.sel{background:rgba(232,184,109,.07);border-color:rgba(232,184,109,.25);}
.li-thumb{width:40px;height:40px;border-radius:6px;object-fit:cover;flex-shrink:0;background:var(--card2);}
.li-thumb-ph{width:40px;height:40px;border-radius:6px;flex-shrink:0;background:var(--card2);display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:var(--muted);}
.li-body{flex:1;min-width:0;}
.li-name{font-size:.78rem;font-weight:600;line-height:1.3;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.li-count{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--muted);margin-top:1px;}
.lists-empty{padding:20px;text-align:center;color:var(--muted);font-size:.78rem;}

/* ── Right panel: detail ── */
.detail-panel{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}
.detail-empty{flex:1;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:.88rem;}
.detail-header{padding:8px 70px 8px 14px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;}
.dh-name{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:900;color:var(--gold);line-height:1.2;}
.dh-name a{color:inherit;text-decoration:none;}
.dh-name a:hover{opacity:.8;}
.dh-meta{font-family:'DM Mono',monospace;font-size:.60rem;color:var(--muted);margin-top:4px;display:flex;gap:14px;flex-wrap:wrap;}
.dh-meta span{white-space:nowrap;}
.dh-visited{color:var(--teal);}

/* ── Map ── */
#map{height:220px;flex-shrink:0;background:var(--bg);}
.leaflet-container{background:#0c0e14;}
.leaflet-popup-content-wrapper{background:var(--card2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.80rem;}
.leaflet-popup-tip{background:var(--card2);}
.leaflet-popup-content{margin:10px 14px;}

/* ── Venue feed ── */
.venues-scroll{flex:1;overflow-y:auto;padding:8px 70px 8px 10px;}
.venues-scroll::-webkit-scrollbar{width:3px;}
.venues-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.vcard{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 13px 9px;margin-bottom:6px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden;}
.vcard::after{content:'';position:absolute;top:0;left:14px;right:14px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.15;}
.vcard:hover{border-color:rgba(232,184,109,.3);}
.vcard.sel{border-color:var(--gold);}
.vc-head{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.vc-cat-icon{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.vc-name{font-size:.84rem;font-weight:700;line-height:1.28;flex:1;}
.vc-name a{color:var(--text);text-decoration:none;}
.vc-name a:hover{color:var(--gold);}
.vc-closed{font-family:'DM Mono',monospace;font-size:.48rem;color:#ef4444;border:1px solid rgba(239,68,68,.45);border-radius:3px;padding:1px 4px;margin-left:4px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.vc-visited{font-family:'DM Mono',monospace;font-size:.48rem;color:var(--teal);border:1px solid rgba(78,201,176,.4);border-radius:3px;padding:1px 4px;margin-left:4px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.vc-saved{font-family:'DM Mono',monospace;font-size:.48rem;color:var(--muted);border:1px solid rgba(107,114,128,.4);border-radius:3px;padding:1px 4px;margin-left:4px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.vc-rating{font-size:.80rem;flex-shrink:0;}
.vc-foot{display:flex;align-items:center;gap:6px;margin-top:4px;flex-wrap:nowrap;overflow:hidden;}
.vc-cat{font-family:'DM Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;color:var(--teal);white-space:nowrap;flex-shrink:0;}
.vc-sep{color:var(--border);font-size:.6rem;flex-shrink:0;}
.vc-loc{font-size:.68rem;color:var(--muted);display:flex;align-items:center;gap:4px;min-width:0;overflow:hidden;flex-shrink:1;}
.vc-loc .fi{width:1.1em;height:.85em;border-radius:2px;flex-shrink:0;background-size:cover;background-position:50%;display:inline-block;}
.vc-loc-text{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0;}
.vc-date{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--muted);white-space:nowrap;margin-left:auto;flex-shrink:0;}
.vc-dist{font-family:'DM Mono',monospace;font-size:.52rem;color:var(--teal);white-space:nowrap;flex-shrink:0;margin-left:auto;}

/* ── Add-venue panel (fixed bottom sheet) ── */
#addVenueBar{position:fixed;bottom:0;left:0;right:0;z-index:600;max-height:62vh;background:var(--card);border-top:2px solid rgba(78,201,176,.4);border-radius:14px 14px 0 0;box-shadow:0 -8px 32px rgba(0,0,0,.6);display:flex;flex-direction:column;overflow:hidden;}
@media(min-width:700px){#addVenueBar{left:300px;right:54px;}}
.avb-header{display:flex;align-items:center;padding:9px 14px 7px;border-bottom:1px solid var(--border);flex-shrink:0;gap:8px;}
.avb-title{font-family:'DM Mono',monospace;font-size:.58rem;text-transform:uppercase;letter-spacing:.14em;color:var(--teal);flex:1;}
.avb-close-btn{font-size:.78rem;background:transparent;border:1px solid var(--border);border-radius:5px;color:var(--muted);cursor:pointer;padding:2px 8px;line-height:1.5;transition:all .15s;}
.avb-close-btn:hover{border-color:#ef4444;color:#ef4444;}
.avb-controls{padding:8px 10px 4px;flex-shrink:0;}
.avb-row{display:flex;align-items:center;gap:6px;margin-bottom:6px;}
.venue-srch-input{flex:1;background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:6px 10px;color:var(--text);font-size:.75rem;outline:none;font-family:'DM Sans',sans-serif;}
.venue-srch-input:focus{border-color:var(--teal);}
.avb-near-btn{font-family:'DM Mono',monospace;font-size:.54rem;text-transform:uppercase;letter-spacing:.06em;padding:6px 10px;background:var(--card2);border:1px solid var(--border);border-radius:6px;color:var(--muted);cursor:pointer;transition:all .15s;white-space:nowrap;flex-shrink:0;}
.avb-near-btn:hover,.avb-near-btn.active{border-color:var(--teal);color:var(--teal);background:rgba(78,201,176,.08);}
.avb-search-btn{font-family:'DM Mono',monospace;font-size:.54rem;text-transform:uppercase;letter-spacing:.06em;padding:6px 12px;background:var(--teal);border:1px solid var(--teal);border-radius:6px;color:#0d1117;cursor:pointer;transition:all .15s;width:100%;}
.avb-cat-hint{font-size:.65rem;color:var(--muted);padding:2px 2px 4px;line-height:1.4;}
.avb-select{flex:1;min-width:0;background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:5px 8px;color:var(--text);font-size:.65rem;font-family:'DM Mono',monospace;outline:none;cursor:pointer;}
.avb-select:focus{border-color:var(--teal);}
#vsearchResults{flex:1;overflow-y:auto;padding:4px 10px 12px;display:flex;flex-direction:column;gap:4px;}
#vsearchResults::-webkit-scrollbar{width:3px;}
#vsearchResults::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.vsearch-result{display:flex;align-items:center;gap:8px;padding:7px 9px;background:var(--card2);border:1px solid var(--border);border-radius:8px;}
.vsearch-result-body{flex:1;min-width:0;}
.vsearch-result-name{font-size:.80rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.vsearch-result-meta{font-family:'DM Mono',monospace;font-size:.55rem;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.vsearch-add-btn{font-family:'DM Mono',monospace;font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;padding:4px 9px;background:transparent;border:1px solid rgba(78,201,176,.5);border-radius:5px;color:var(--teal);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0;}
.vsearch-add-btn:hover{background:rgba(78,201,176,.1);border-color:var(--teal);}
.vsearch-add-btn:disabled{opacity:.4;cursor:default;}
.add-venue-btn{font-family:'DM Mono',monospace;font-size:.50rem;text-transform:uppercase;letter-spacing:.07em;padding:3px 9px;background:transparent;border:1px solid rgba(78,201,176,.45);border-radius:5px;color:var(--teal);cursor:pointer;transition:all .15s;margin-top:5px;display:inline-block;}
.add-venue-btn:hover,.add-venue-btn.active{border-color:var(--teal);background:rgba(78,201,176,.09);}
.vc-custom{border-color:rgba(78,201,176,.25);}
.vc-custom-tag{font-family:'DM Mono',monospace;font-size:.46rem;color:var(--teal);border:1px solid rgba(78,201,176,.4);border-radius:3px;padding:1px 4px;margin-left:4px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.vc-remove-btn{font-family:'DM Mono',monospace;font-size:.50rem;text-transform:uppercase;letter-spacing:.05em;padding:2px 7px;background:transparent;border:1px solid rgba(239,68,68,.4);border-radius:4px;color:#ef4444;cursor:pointer;transition:all .15s;white-space:nowrap;flex-shrink:0;}
.vc-remove-btn:hover{background:rgba(239,68,68,.1);border-color:#ef4444;}

/* ── Geolocation ── */
#geobar{padding:5px 10px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;display:flex;align-items:center;gap:8px;}
.locate-btn{font-family:'DM Mono',monospace;font-size:.56rem;text-transform:uppercase;letter-spacing:.08em;padding:4px 10px;background:var(--card2);border:1px solid var(--border);border-radius:6px;color:var(--muted);cursor:pointer;transition:all .15s;white-space:nowrap;}
.locate-btn:hover{border-color:var(--teal);color:var(--teal);}
.locate-btn.located{border-color:var(--teal);color:var(--teal);}
#locateStatus{font-family:'DM Mono',monospace;font-size:.55rem;color:var(--muted);}
.geo-marker{background:none!important;border:none!important;}
.geo-dot{width:12px;height:12px;background:#4fc3f7;border-radius:50%;border:2px solid white;position:absolute;top:4px;left:4px;box-shadow:0 0 4px rgba(79,195,247,.8);}
.geo-ring{width:20px;height:20px;background:rgba(79,195,247,.25);border-radius:50%;position:absolute;top:0;left:0;animation:geo-pulse 2s ease-out infinite;}
@keyframes geo-pulse{0%{opacity:.8;transform:scale(.8);}100%{opacity:0;transform:scale(2.2);}}

@media(max-width:700px){
  .lists-panel{width:100%;border-right:none;display:none;}
  .lists-panel.mobile-open{display:flex;}
  .detail-panel{width:100%;}
  #map{height:160px;}
}
@media(max-width:480px){
  .detail-header{padding:8px 10px 6px;}
  .dh-name{font-size:.90rem;}
  .vcard{padding:8px 10px 7px;}
}
</style>
</head>
<body>
<div class="page">
  <nav class="topnav">
    <a href="index.html" class="topnav-logo">Check-in Journal</a>
    <span class="topnav-current">My Lists</span>
    <button class="gs-btn" style="margin-left:auto" onclick="gsOpen()"><span>⌕</span> Search<kbd>⌘K</kbd></button>
  </nav>
<div class="gs-overlay" id="gsOverlay" onclick="if(event.target===this)gsClose()">
  <div class="gs-modal"><div class="gs-input-wrap"><span class="gs-icon">⌕</span><input class="gs-input" id="gsInput" type="text" placeholder="Search venues, cities, trips…" autocomplete="off" spellcheck="false"><span class="gs-esc-hint" onclick="gsClose()">esc</span></div></div>
</div>
<div class="page-insight" id="page-insight"></div>
  <div class="content">
    <div class="lists-panel" id="listsPanel">
      <div class="lists-search-wrap">
        <input class="lists-search" id="listSearch" type="text" placeholder="Filter lists…" oninput="filterLists(this.value)" autocomplete="off">
      </div>
      <div class="sort-bar">
        <button class="sort-btn" id="srtAZ" onclick="setSort('az')">A–Z</button>
        <button class="sort-btn active" id="srtUpdated" onclick="setSort('updated')">Last Updated</button>
        <button class="sort-btn" id="srtVisited" onclick="setSort('visited')">Recent Visit</button>
      </div>
      <div class="lists-scroll" id="listsScroll"></div>
    </div>
    <div class="detail-panel" id="detailPanel">
      <div class="detail-empty" id="detailEmpty">← Select a list</div>
      <div id="detailContent" style="display:none;flex-direction:column;overflow:hidden;flex:1;">
        <div class="detail-header" id="detailHeader"></div>
        <div id="geobar" style="display:none;">
          <button class="locate-btn" id="locateBtn" onclick="geoLocate()">📍 Locate me</button>
          <span id="locateStatus"></span>
        </div>
        <div id="addVenueBar" style="display:none;">
          <div class="avb-header">
            <span class="avb-title">Add Venue to List</span>
            <button class="avb-close-btn" onclick="toggleAddBar()">&#x2715;</button>
          </div>
          <div class="avb-controls">
            <div class="avb-row">
              <input class="venue-srch-input" id="venueSearchInput" type="text" placeholder="Type to search venues…" autocomplete="off" spellcheck="false">
              <button class="avb-near-btn" id="avbNearBtn" onclick="_vsearchNearby()">&#x1F4CD; Nearby</button>
            </div>
            <div class="avb-row">
              <input class="venue-srch-input" id="vsCityInput" type="text" placeholder="City / country (optional)" autocomplete="off" spellcheck="false" style="flex:1;">
            </div>
            <div class="avb-row">
              <button class="avb-search-btn" id="avbSearchBtn" onclick="_vsearchManual()">&#x1F50D; Search</button>
            </div>
            <div class="avb-row">
              <select class="avb-select" id="vsCatSelect" onchange="_vsearchIfActive();document.getElementById('vsCatHint').style.display=this.value?'block':'none';">
                <option value="">All categories</option>
                <optgroup label="☕ Dining &amp; Drinking">
                  <option value="13000">All Dining &amp; Drinking</option>
                  <option value="13032">Cafe, Coffee &amp; Tea</option>

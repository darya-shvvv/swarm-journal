// Sorted longest-key-first so substring fallback prefers most-specific match
const _CAT_IC_NORM=Object.entries(CAT_ICON).map(([k,v])=>[k.toLowerCase().trim(),v]).sort((a,b)=>b[0].length-a[0].length);
function catIcon(cat){
  if(!cat) return {em:'📍',bg:'#4a5270'};
  // 1. Exact match
  const e=CAT_ICON[cat]; if(e) return {em:e[0],bg:e[1]};
  // 2. Case-insensitive / whitespace-normalised match, or subcategory suffix match
  // e.g. "Specialty Coffee Shop" → "Coffee Shop"; "Third Wave Coffee Shop" → "Coffee Shop"
  const n=cat.toLowerCase().trim();
  for(const [k,v] of _CAT_IC_NORM) if(n===k||n.includes(k)) return {em:v[0],bg:v[1]};
  return {em:'📍',bg:'#4a5270'};
}

const RATING_EMOJI={'like':'❤️','neutral':'😐','dislike':'💔'};

// ── List rendering ────────────────────────────────────────────────────────────
let _sortMode = 'updated';
let filteredLists = [];
let selIdx = -1;
let map = null, mapMarkers = [], venueMarkerMap = {};
let userLat = null, userLng = null, userMarker = null;

function haversine(a,b,c,d){
  const R=6371,dL=(c-a)*Math.PI/180,dN=(d-b)*Math.PI/180,
    e=Math.sin(dL/2)*Math.sin(dL/2)+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dN/2)*Math.sin(dN/2);
  return R*2*Math.atan2(Math.sqrt(e),Math.sqrt(1-e));
}
function fmtDist(km){return km<1?Math.round(km*1000)+'\u2009m':km.toFixed(1)+'\u2009km';}

function geoLocate(){
  if(!navigator.geolocation){document.getElementById('locateStatus').textContent='Not supported';return;}
  const btn=document.getElementById('locateBtn');
  const st=document.getElementById('locateStatus');
  st.textContent='Locating\u2026';
  navigator.geolocation.getCurrentPosition(function(pos){
    userLat=pos.coords.latitude;userLng=pos.coords.longitude;
    st.textContent='Located \u2713';
    btn.classList.add('located');
    if(map){
      if(userMarker) map.removeLayer(userMarker);
      const icon=L.divIcon({
        html:'<div class="geo-dot"></div><div class="geo-ring"></div>',
        className:'geo-marker',iconSize:[20,20],iconAnchor:[10,10]
      });
      userMarker=L.marker([userLat,userLng],{icon}).addTo(map);
      userMarker.bindPopup('<b>You are here</b>');
    }
    updateDistances();
  },function(e){
    st.textContent=e.code===1?'Permission denied':'Location error';
  },{enableHighAccuracy:true,timeout:10000});
}

function updateDistances(){
  if(userLat===null||selIdx<0) return;
  const lst=LISTS[selIdx];
  if(!lst) return;
  (lst.venues||[]).forEach(function(v,vi){
    const el=document.getElementById('lvc_dist_'+vi);
    if(!el) return;
    if(v.lat&&v.lng){
      const d=haversine(userLat,userLng,parseFloat(v.lat),parseFloat(v.lng));
      el.textContent=fmtDist(d);
      el.style.display='';
    }
  });
}

function _maxVisitTs(lst){
  return Math.max(0,...(lst.venues||[]).map(v=>v.lts||0));
}

function _applySortFilter(q){
  const lq = (q||'').toLowerCase();
  let base = lq ? LISTS.filter(l=>(l.name||'').toLowerCase().includes(lq)) : LISTS.slice();
  if(_sortMode==='az'){
    base.sort((a,b)=>(a.name||'').localeCompare(b.name||''));
  } else if(_sortMode==='updated'){
    base.sort((a,b)=>(b.updatedAt||0)-(a.updatedAt||0));
  } else if(_sortMode==='visited'){
    base.sort((a,b)=>_maxVisitTs(b)-_maxVisitTs(a));
  }
  filteredLists = base;
}

function setSort(mode){
  _sortMode = mode;
  document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));
  const map2={'az':'srtAZ','updated':'srtUpdated','visited':'srtVisited'};
  const btn=document.getElementById(map2[mode]);
  if(btn) btn.classList.add('active');
  _applySortFilter(document.getElementById('listSearch').value);
  renderListItems();
}

function renderListItems(){
  const el = document.getElementById('listsScroll');
  if(!filteredLists.length){
    el.innerHTML = '<div class="lists-empty">No lists found</div>';
    return;
  }
  el.innerHTML = filteredLists.map((lst, fi)=>{
    const origIdx = LISTS.indexOf(lst);
    const thumb = lst.cover
      ? `<img class="li-thumb" src="${esc(lst.cover)}" alt="" loading="lazy" onerror="this.style.display='none'">`
      : `<div class="li-thumb-ph">📋</div>`;
    const sel = origIdx === selIdx ? ' sel' : '';
    return `<div class="list-item${sel}" onclick="selectList(${origIdx})">${thumb}<div class="li-body"><div class="li-name">${esc(lst.name)}</div><div class="li-count">${lst.count} venues</div></div></div>`;
  }).join('');
}

function filterLists(q){
  _applySortFilter(q);
  renderListItems();
}

function selectList(idx){
  selIdx = idx;
  renderListItems();
  const lst = LISTS[idx];
  if(!lst) return;

  // Reset add bar for new list
  _customListId = lst.id;
  _addBarOpen = false;
  document.getElementById('addVenueBar').style.display = 'none';
  document.getElementById('vsearchResults').innerHTML = '';
  document.getElementById('venueSearchInput').value = '';

  document.getElementById('detailEmpty').style.display = 'none';
  const dc = document.getElementById('detailContent');
  dc.style.display = 'flex';
  dc.style.flexDirection = 'column';
  dc.style.overflow = 'hidden';
  dc.style.flex = '1';

  // Header
  const visitedCount = (lst.venues||[]).filter(v=>v.visited).length;
  const withCoords = (lst.venues||[]).filter(v=>v.lat&&v.lng).length;
  document.getElementById('detailHeader').innerHTML = `
    <div class="dh-name">${lst.url?`<a href="${esc(lst.url)}" target="_blank" rel="noopener">${esc(lst.name)}</a>`:esc(lst.name)}</div>
    <div class="dh-meta">
      <span>${lst.count} venues</span>
      <span class="dh-visited">✓ ${visitedCount} visited</span>
      ${withCoords?`<span>${withCoords} on map</span>`:''}
    </div>
    <button class="add-venue-btn" id="addVenueToggle" onclick="toggleAddBar()">+ Add venue</button>`;

  // Map
  const mapEl = document.getElementById('map');
  if(withCoords){
    mapEl.style.display = 'block';
    document.getElementById('geobar').style.display = 'flex';
    if(!map){
      map = L.map('map',{preferCanvas:true}).setView([30,15],2);
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
    }
    mapMarkers.forEach(m=>map.removeLayer(m));
    mapMarkers = []; venueMarkerMap = {};
    const bounds = [];
    (lst.venues||[]).forEach((v,vi)=>{
      if(!v.lat||!v.lng) return;
      const col = v.visited ? '#4ec9b0' : '#e8b86d';
      const m = L.circleMarker([parseFloat(v.lat),parseFloat(v.lng)],{radius:5,fillColor:col,fillOpacity:.75,color:col,weight:1,_baseCol:col}).addTo(map);
      const loc = [v.nci||v.city,v.nc||v.country].filter(Boolean).join(', ');
      const fsqLink = v.u ? `<br><a href="${esc(v.u)}" target="_blank" rel="noopener" style="font-size:.72rem;color:#4ec9b0;">Foursquare ↗</a>` : '';
      m.bindPopup(`<b>${esc(v.n||'')}</b><br><span style="font-size:.75rem;color:#9ca3af;">${esc(loc)}</span>${fsqLink}`,{maxWidth:220});
      venueMarkerMap[vi] = m;
      mapMarkers.push(m);
      bounds.push([parseFloat(v.lat),parseFloat(v.lng)]);
    });
    if(bounds.length) map.fitBounds(bounds,{padding:[20,20],maxZoom:14});
    setTimeout(()=>map.invalidateSize(),50);
  } else {
    mapEl.style.display = 'none';
    document.getElementById('geobar').style.display = 'none';
  }

  // Re-add user marker if location already known
  if(userLat!==null&&map&&withCoords){
    if(userMarker) map.removeLayer(userMarker);
    const icon=L.divIcon({html:'<div class="geo-dot"></div><div class="geo-ring"></div>',className:'geo-marker',iconSize:[20,20],iconAnchor:[10,10]});
    userMarker=L.marker([userLat,userLng],{icon}).addTo(map);
    userMarker.bindPopup('<b>You are here</b>');
  }

  // Venue cards
  document.getElementById('venuesScroll').innerHTML = (lst.venues||[]).map((v,vi)=>{
    const{em,bg}=catIcon(v.cat||'');
    const closedBadge = v.cl ? '<span class="vc-closed">CLOSED</span>' : '';
    const visitBadge = v.visited ? '<span class="vc-visited">✓ visited</span>' : '<span class="vc-saved">saved</span>';
    const ratingBadge = v.r ? `<span class="vc-rating">${RATING_EMOJI[v.r]||''}</span>` : '';
    const nameLabel = v.u ? `<a href="${esc(v.u)}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(v.n||'Unknown venue')}</a>` : esc(v.n||'Unknown venue');
    const flag = (v.nc||v.country) ? flagHtml(v.nc||v.country) : '';
    const locParts = [v.nci||v.city, v.nc||v.country].filter(Boolean);
    const locStr = esc(locParts.join(', '));
    const locHtml = (flag||locStr)
      ? `<span class="vc-sep">·</span><span class="vc-loc">${flag}${locStr?`<span class="vc-loc-text">${locStr}</span>`:''}</span>`
      : '';
    const dateHtml = v.ld ? `<span class="vc-date">${v.ld}</span>` : '';
    return `<div class="vcard" id="lvc_${vi}" onclick="selectVenue(${vi},${idx})" onmouseenter="hoverVenueMarker(${vi})" onmouseleave="unhoverVenueMarker(${vi})">
      <div class="vc-head">
        <div class="vc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
        <div class="vc-name">${nameLabel}${visitBadge}${closedBadge}</div>
        ${ratingBadge}
      </div>
      <div class="vc-foot">
        <span class="vc-cat">${esc(v.cat||'')}</span>
        ${locHtml}${dateHtml}
        ${v.lat&&v.lng?`<span class="vc-dist" id="lvc_dist_${vi}" style="display:none"></span>`:''}
      </div>
    </div>`;
  }).join('');
  if(userLat!==null) updateDistances();
  _loadCustomVenues(lst.id);
}

function selectVenue(vi, listIdx){
  document.querySelectorAll('.vcard.sel').forEach(el=>el.classList.remove('sel'));
  const el = document.getElementById('lvc_'+vi);
  if(el){el.classList.add('sel');}
  if(!map) return;
  const m = venueMarkerMap[vi];
  if(m){
    map.panTo(m.getLatLng(),{animate:true});
    m.openPopup();
  }
}

function hoverVenueMarker(vi){
  const m = venueMarkerMap[vi];
  if(m) m.setStyle({radius:9,weight:2,color:'#fff',fillOpacity:1});
}
function unhoverVenueMarker(vi){
  const m = venueMarkerMap[vi];
  if(m){
    const col = m.options._baseCol || '#e8b86d';
    m.setStyle({radius:5,weight:1,color:col,fillOpacity:.75});
  }
}

// ── Custom venue overlay ──────────────────────────────────────────────────────
let _customListId = null;
let _addBarOpen = false;
let _vsearchTimer = null;
let _vsearchVenues = [];
let _vsearchMode = ''; // '' = text, 'nearby' = geo mode
let _vsearchAbort = null; // AbortController for in-flight request
let _vsearchCursor = null; // FSQ pagination cursor for current search
let _vsearchLastArgs = null; // {q, lat, lng} for "Load more"
const _vsearchCache = new Map(); // key → {results, nextCursor, ts}
const _VCACHE_TTL = 5 * 60 * 1000; // 5 min

function toggleAddBar() {
  _addBarOpen = !_addBarOpen;
  const bar = document.getElementById('addVenueBar');
  bar.style.display = _addBarOpen ? 'flex' : 'none';
  const btn = document.getElementById('addVenueToggle');
  if (btn) btn.classList.toggle('active', _addBarOpen);
  if (_addBarOpen) {
    setTimeout(() => document.getElementById('venueSearchInput').focus(), 50);
    // Auto-load nearby if location already known
    if (userLat !== null) {
      _vsearchMode = 'nearby';
      const nb = document.getElementById('avbNearBtn');
      if (nb) nb.classList.add('active');
      _vsearch('', userLat, userLng);
    }
  } else {
    document.getElementById('vsearchResults').innerHTML = '';
    document.getElementById('venueSearchInput').value = '';
    document.getElementById('vsCityInput').value = '';
    _vsearchMode = '';
    _vsearchCursor = null;
    _vsearchLastArgs = null;
    const nb = document.getElementById('avbNearBtn');
    if (nb) { nb.textContent = '\u{1F4CD} Nearby'; nb.classList.remove('active'); }
  }
}

document.getElementById('venueSearchInput').addEventListener('input', function() {
  clearTimeout(_vsearchTimer);
  _vsearchMode = '';
  const nb = document.getElementById('avbNearBtn');
  if (nb) nb.classList.remove('active');
  const q = this.value.trim();
  if (!q) { document.getElementById('vsearchResults').innerHTML = ''; return; }
  _vsearchTimer = setTimeout(() => _vsearch(q), 600);
});

document.getElementById('vsCityInput').addEventListener('input', function() {
  clearTimeout(_vsearchTimer);
  const q = (document.getElementById('venueSearchInput').value || '').trim();
  if (q.length >= 2 || _vsearchMode === 'nearby') {
    _vsearchTimer = setTimeout(() => {
      if (_vsearchMode === 'nearby') _vsearch('', userLat, userLng);
      else _vsearch(q);
    }, 600);
  }
});

function _vsearchManual() {
  clearTimeout(_vsearchTimer);
  if (_vsearchMode === 'nearby' && userLat !== null) {
    _vsearch('', userLat, userLng);
  } else {
    const q = (document.getElementById('venueSearchInput').value || '').trim();
    _vsearchMode = '';
    const nb = document.getElementById('avbNearBtn');
    if (nb) nb.classList.remove('active');
    _vsearch(q);
  }
}

function _vsearchIfActive() {
  clearTimeout(_vsearchTimer);
  if (_vsearchMode === 'nearby') {
    _vsearchTimer = setTimeout(() => _vsearch('', userLat, userLng), 400);
  } else {
    const q = (document.getElementById('venueSearchInput').value || '').trim();
    if (q.length >= 2) _vsearchTimer = setTimeout(() => _vsearch(q), 400);
  }
}

function _vsearchNearby() {
  const nb = document.getElementById('avbNearBtn');
  if (userLat !== null) {
    _vsearchMode = 'nearby';
    if (nb) nb.classList.add('active');
    _vsearch('', userLat, userLng);
    return;
  }
  if (!navigator.geolocation) {
    document.getElementById('vsearchResults').innerHTML = '<div style="font-size:.72rem;color:var(--muted);padding:6px 4px">Geolocation not supported</div>';
    return;
  }
  if (nb) nb.textContent = '\u23F3 Locating\u2026';
  navigator.geolocation.getCurrentPosition(function(pos) {
    userLat = pos.coords.latitude; userLng = pos.coords.longitude;
    const locBtn = document.getElementById('locateBtn');
    if (locBtn) locBtn.classList.add('located');
    document.getElementById('locateStatus').textContent = 'Located \u2713';
    if (map) {
      if (userMarker) map.removeLayer(userMarker);
      const icon = L.divIcon({html:'<div class="geo-dot"></div><div class="geo-ring"></div>',className:'geo-marker',iconSize:[20,20],iconAnchor:[10,10]});
      userMarker = L.marker([userLat, userLng], {icon}).addTo(map);
      userMarker.bindPopup('<b>You are here</b>');
    }
    if (nb) { nb.textContent = '\u{1F4CD} Nearby'; nb.classList.add('active'); }
    _vsearchMode = 'nearby';
    _vsearch('', userLat, userLng);
  }, function(e) {
    if (nb) nb.textContent = '\u{1F4CD} Nearby';
    document.getElementById('vsearchResults').innerHTML = '<div style="font-size:.72rem;color:var(--muted);padding:6px 4px">' + (e.code===1?'Location permission denied':'Location unavailable') + '</div>';
  }, {enableHighAccuracy:true, timeout:10000});
}

async function _vsearch(q, lat, lng) {
  _vsearchCursor = null;
  _vsearchLastArgs = {q, lat, lng};
  _vsearchVenues = [];
  await _vsearchFetch(q, lat, lng, null, false);
}

async function _vsearchLoadMore() {
  if (!_vsearchCursor || !_vsearchLastArgs) return;
  const {q, lat, lng} = _vsearchLastArgs;
  await _vsearchFetch(q, lat, lng, _vsearchCursor, true);
}

async function _vsearchFetch(q, lat, lng, cursor, append) {
  const el = document.getElementById('vsearchResults');
  const catSel = document.getElementById('vsCatSelect');
  const sortSel = document.getElementById('vsSortSelect');
  const cityEl = document.getElementById('vsCityInput');
  const cat  = catSel  ? catSel.value  : '';
  const sort = sortSel ? sortSel.value : 'RELEVANCE';
  const near = (cityEl ? cityEl.value.trim() : '');
  const ll = lat != null && lng != null ? lat + ',' + lng : null;
  // FSQ API ignores the `categories` param server-side; work around it:
  // use the category label as the text query so FSQ text-ranks relevant venues,
  // then apply client-side name filter below on a larger result set.
  const catLabel = (catSel && catSel.value)
    ? catSel.options[catSel.selectedIndex].text.trim().toLowerCase()
    : '';
  // When text + category are both present, combine them so FSQ ranks both signals.
  // When only category is selected, use its label as the sole text query.
  const catText = catLabel ? catSel.options[catSel.selectedIndex].text.trim() : '';
  const effectiveQ = q && catText ? q + ' ' + catText : (q || catText);

  // For non-cursor fetch, check cache (cursor pages are not cached)
  if (!cursor) {
    const cacheKey = JSON.stringify({effectiveQ, ll, near, catLabel, sort});
    const cached = _vsearchCache.get(cacheKey);
    if (cached && (Date.now() - cached.ts) < _VCACHE_TTL) {
      _vsearchVenues = cached.results;
      _vsearchCursor = cached.nextCursor || null;
      _vsearchRender(append);
      return;
    }
  }

  if (!append) {
    el.innerHTML = '<div style="font-size:.72rem;color:var(--muted);padding:6px 4px">Searching\u2026</div>';
  } else {
    const lb = document.getElementById('vsearchLoadMore');
    if (lb) { lb.disabled = true; lb.textContent = '\u2026'; }
  }

  if (_vsearchAbort) _vsearchAbort.abort();
  _vsearchAbort = new AbortController();
  try {
    const p = new URLSearchParams();
    if (effectiveQ) p.set('q', effectiveQ);
    if (ll) p.set('ll', ll);
    else if (near) p.set('near', near);
    // FSQ ignores `categories` param server-side; omit it, use effectiveQ for bias instead.
    // When cat filter is active, fetch 50 results so client-side filter has more candidates.
    p.set('limit', catLabel ? '50' : '12');
    if (sort && sort !== 'RELEVANCE') p.set('sort', sort);
    if (cursor) p.set('cursor', cursor);
    const res = await fetch('/api/search-venues?' + p.toString(), { signal: _vsearchAbort.signal });
    const data = await res.json();
    const raw = data.results || [];
    const newVenues = catLabel
      ? raw.filter(v => (v.categories || []).some(c => {
          const n = (c.name || '').toLowerCase();
          return n === catLabel || n.includes(catLabel) || catLabel.includes(n);
        }))
      : raw;
    _vsearchCursor = catLabel ? null : (data.nextCursor || null);
    if (append) {
      const offset = _vsearchVenues.length;
      _vsearchVenues = _vsearchVenues.concat(newVenues);
      _vsearchRender(true, offset);
    } else {
      _vsearchVenues = newVenues;
      if (!cursor) {
        const cacheKey = JSON.stringify({effectiveQ, ll, near, catLabel, sort});
        _vsearchCache.set(cacheKey, { results: _vsearchVenues, nextCursor: _vsearchCursor, ts: Date.now() });
      }
      _vsearchRender(false);
    }
  } catch(err) {
    if (err.name === 'AbortError') return;
    if (!append) {
      el.innerHTML = '<div style="font-size:.72rem;color:var(--muted);padding:6px 4px">Search failed</div>';
    }
    _vsearchVenues = append ? _vsearchVenues : [];
  }
}

function _vsearchRender(append, appendOffset) {
  const el = document.getElementById('vsearchResults');
  if (!_vsearchVenues.length) {
    el.innerHTML = '<div style="font-size:.72rem;color:var(--muted);padding:6px 4px">No results</div>';
    return;
  }
  const renderFrom = append ? (appendOffset || 0) : 0;
  const newHtml = _vsearchVenues.slice(renderFrom).map((v, idx) => {
    const i = renderFrom + idx;
    const c0 = (v.categories || [])[0];
    const loc = v.location || {};
    const cityPart = loc.locality || loc.city || '';
    const metaParts = [c0 ? c0.name : '', [cityPart, loc.country||''].filter(Boolean).join(', ')].filter(Boolean);
    return `<div class="vsearch-result">
      <div class="vsearch-result-body">
        <div class="vsearch-result-name">${esc(v.name||'')}</div>
        ${metaParts.length?`<div class="vsearch-result-meta">${esc(metaParts.join(' \u00b7 '))}</div>`:''}
      </div>
      <button class="vsearch-add-btn" data-vi="${i}" onclick="_addCustomVenue(${i})">+ Add</button>
    </div>`;
  }).join('');

  // Remove existing "Load more" button before re-adding
  const existing = document.getElementById('vsearchLoadMore');
  if (existing) existing.remove();

  if (append) {
    el.insertAdjacentHTML('beforeend', newHtml);
  } else {
    el.innerHTML = newHtml;
  }

  if (_vsearchCursor) {
    el.insertAdjacentHTML('beforeend',
      '<button id="vsearchLoadMore" class="avb-near-btn" style="width:100%;margin-top:6px;justify-content:center" onclick="_vsearchLoadMore()">Load more</button>');
  }
}

async function _addCustomVenue(vi) {
  if (!_customListId) return;
  const v = _vsearchVenues[vi];
  if (!v) return;
  const btn = document.querySelector(`.vsearch-add-btn[data-vi="${vi}"]`);
  if (btn) { btn.disabled = true; btn.textContent = '\u2026'; }
  const geo = (v.geocodes || {}).main || {};
  const loc = v.location || {};
  const cat = (v.categories || [])[0];
  const resp = await fetch('/api/custom-list', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      listId: _customListId,
      venueId: v.fsq_id,
      venueName: v.name,
      lat: geo.latitude ?? null,
      lng: geo.longitude ?? null,
      category: cat ? cat.name : null,
      address: loc.formatted_address || loc.address || null,
    })
  });
  if (resp.ok) {
    if (btn) btn.textContent = '\u2713';
    _loadCustomVenues(_customListId);
  } else {
    if (btn) { btn.disabled = false; btn.textContent = '+ Add'; }
  }
}

async function _removeCustomVenue(venueId) {
  if (!_customListId) return;
  await fetch('/api/custom-list?listId=' + encodeURIComponent(_customListId) +
    '&venueId=' + encodeURIComponent(venueId), { method: 'DELETE' });
  _loadCustomVenues(_customListId);
}

async function _loadCustomVenues(listId) {
  try {
    const res = await fetch('/api/custom-list?listId=' + encodeURIComponent(listId));
    if (!res.ok) return;
    const venues = await res.json();
    _renderCustomVenues(venues);
  } catch { /* offline or no function — silent */ }
}

function _renderCustomVenues(customs) {
  document.querySelectorAll('.vc-custom-card').forEach(el => el.remove());
  // Update the count in the detail header to reflect custom additions
  const lst = selIdx >= 0 ? filteredLists[selIdx] : null;
  const countEl = document.querySelector('#detailHeader .dh-meta span:first-child');
  if (countEl && lst) {
    const base = lst.count || 0;
    countEl.textContent = (base + customs.length) + ' venues';
  }
  if (!customs.length) return;
  const scroll = document.getElementById('venuesScroll');
  const frag = document.createDocumentFragment();
  customs.forEach(v => {
    const { em, bg } = catIcon(v.category || '');
    const addrHtml = v.address ? `<span class="vc-sep">\u00b7</span><span class="vc-loc"><span class="vc-loc-text">${esc(v.address)}</span></span>` : '';
    const fsqUrl = `https://foursquare.com/v/${encodeURIComponent(v.venue_id)}`;
    const nameHtml = `<a href="${fsqUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(v.venue_name)}</a><span class="vc-custom-tag">ADDED</span>`;
    const div = document.createElement('div');
    div.className = 'vcard vc-custom vc-custom-card';
    div.innerHTML = `<div class="vc-head">
      <div class="vc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
      <div class="vc-name">${nameHtml}</div>
      <button class="vc-remove-btn" onclick="_removeCustomVenue('${esc(v.venue_id)}')">Remove</button>
    </div>
    <div class="vc-foot">
      ${v.category ? `<span class="vc-cat">${esc(v.category)}</span>` : ''}${addrHtml}
    </div>`;
    frag.appendChild(div);
  });
  scroll.prepend(frag);
}
// ─────────────────────────────────────────────────────────────────────────────

_applySortFilter('');
renderListItems();
if(filteredLists.length) selectList(LISTS.indexOf(filteredLists[0]));
</script>

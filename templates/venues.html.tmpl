<meta name="description" content="All unique venues from 65,000+ personal Foursquare check-ins, ranked by visit count with links to Foursquare.">
<link rel="canonical" href="https://4sq.pages.dev/venues.html">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Check-in Journal">
<meta property="og:title" content="Venues — Check-in Journal">
<meta property="og:description" content="All unique venues from 65,000+ personal Foursquare check-ins, ranked by visit count with links to Foursquare.">
<meta property="og:url" content="https://4sq.pages.dev/venues.html">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="Venues — Check-in Journal">
<meta name="twitter:description" content="All unique venues from 65,000+ personal Foursquare check-ins, ranked by visit count with links to Foursquare.">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600&family=DM+Mono&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/6.6.6/css/flag-icons.min.css">

<style>

:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
body.light{--bg:#ddd8cf;--card:#f0ece3;--card2:#e5e0d7;--border:#aaa49a;--gold:#7a3e00;--teal:#155c58;--muted:#54576a;--text:#15172a;--text2:#373b58;}
body.light header{background:linear-gradient(160deg,#d6d1c8 0%,#dedad1 70%);}
body.light .side-nav{background:rgba(220,215,208,0.97);}
body.light .side-nav a:hover,body.light .side-nav button:hover{background:rgba(0,0,0,.08);}
body.light .heatmap-tooltip,body.light .map-status{background:rgba(220,215,208,0.97);}
body.light .card{box-shadow:0 2px 8px rgba(0,0,0,.10);}
body.light a{color:var(--teal);}

*{box-sizing:border-box;margin:0;padding:0;}

body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden;}



.topnav{display:flex;align-items:center;gap:20px;padding:18px 40px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;}
.topnav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--gold);text-decoration:none;}
.topnav a{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);text-decoration:none;transition:color .2s;}
.topnav a:hover{color:var(--gold);}
.topnav-current{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--text);}
.gs-btn{font-family:'DM Mono',monospace;font-size:.60rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:7px 14px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.gs-btn:hover{border-color:var(--gold);color:var(--gold);}
.gs-btn kbd{font-family:'DM Mono',monospace;font-size:.52rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:1px 5px;letter-spacing:0;}
@media(max-width:520px){.gs-btn kbd{display:none;}}
.gs-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:10000;backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding-top:16vh;}.gs-overlay.open{display:flex;}
.gs-modal{background:var(--card);border:1px solid var(--border);border-radius:14px;width:min(560px,92vw);overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.7);}
.gs-input-wrap{display:flex;align-items:center;gap:10px;padding:14px 18px;}
.gs-icon{font-size:1rem;color:var(--muted);}
.gs-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.95rem;}
.gs-input::placeholder{color:var(--muted);}
.gs-esc-hint{font-family:'DM Mono',monospace;font-size:.52rem;color:var(--muted);background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:2px 6px;cursor:pointer;flex-shrink:0;}
.side-nav{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:4000;display:flex;flex-direction:column;gap:0;background:rgba(18,21,31,0.92);border:1px solid var(--border);border-right:none;border-radius:10px 0 0 10px;backdrop-filter:blur(10px);overflow:hidden;}
.side-nav a,.side-nav button{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;width:52px;padding:10px 4px;border:none;background:none;cursor:pointer;color:var(--muted);text-decoration:none;transition:color .15s,background .15s;-webkit-tap-highlight-color:transparent;}
.side-nav a:hover,.side-nav button:hover{background:rgba(255,255,255,.06);color:var(--text);}
.side-nav a.active,.side-nav button.active{color:var(--gold);}
.side-nav .sn-icon{font-size:.95rem;line-height:1;display:inline-block;transition:transform .15s;}
.side-nav a:hover .sn-icon,.side-nav button:hover .sn-icon{transform:scale(1.28);}
.side-nav .sn-lbl{font-family:'DM Mono',monospace;font-size:.42rem;text-transform:uppercase;letter-spacing:.05em;line-height:1;white-space:nowrap;}
.side-nav .sn-sep{width:32px;height:1px;background:var(--border);margin:2px auto;}
.side-nav .sn-sep--pages{width:36px;height:2px;background:var(--border);margin:3px auto;border-radius:1px;}
@media(max-width:900px){.side-nav{display:none;}}



.controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding:10px 40px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;z-index:50;}

.search-box{background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:7px 14px;color:var(--text);font-size:.78rem;outline:none;width:240px;transition:border-color .15s;}

.search-box:focus{border-color:var(--gold);}

.count-lbl{font-family:'DM Mono',monospace;font-size:.68rem;color:var(--muted);margin-left:auto;}



/* Sort pills */

.pill{background:var(--card2);border:1px solid var(--border);border-radius:16px;padding:4px 12px;font-size:.68rem;font-weight:600;cursor:pointer;color:var(--muted);transition:all .15s;letter-spacing:.04em;}

.pill.active{background:rgba(232,184,109,.1);border-color:var(--gold);color:var(--gold);}

.pill:hover:not(.active){border-color:rgba(232,184,109,.3);color:var(--text);}

.lbl-sm{font-size:.62rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;}



/* Table */

.tbl-wrap{flex:1;overflow-y:auto;overflow-x:auto;}

table{width:100%;border-collapse:collapse;min-width:640px;}

thead th{padding:10px 16px;text-align:left;font-size:.60rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:2px solid var(--border);background:var(--card);position:sticky;top:0;z-index:40;cursor:pointer;user-select:none;white-space:nowrap;}

thead th:hover{color:var(--text);}

thead th.sorted{color:var(--gold);}

thead th .sort-ico{margin-left:4px;opacity:.5;font-size:.65rem;}

thead th.sorted .sort-ico{opacity:1;}



tbody tr{border-bottom:1px solid rgba(34,39,56,.5);}

td{padding:10px 16px;vertical-align:middle;}



.rank{font-family:'DM Mono',monospace;font-size:.68rem;color:var(--muted);text-align:right;width:40px;}

.venue-name a,.venue-name a:link{color:#e0e2ec;text-decoration:none;font-weight:600;font-size:.85rem;}

.venue-name a:visited{color:#e0e2ec !important;text-decoration:none;font-weight:600;font-size:.85rem;}

.venue-name a:hover,.venue-name a:visited:hover{color:var(--gold) !important;}

.venue-city{font-size:.68rem;color:var(--muted);margin-top:2px;}

.cat{font-size:.62rem;color:var(--teal);text-transform:uppercase;letter-spacing:.04em;}

.count{font-family:'DM Mono',monospace;font-size:.78rem;color:var(--gold);font-weight:600;text-align:right;}

.years-cell{max-width:220px;}

.yr-chips{display:flex;gap:3px;flex-wrap:wrap;}

.yr{font-family:'DM Mono',monospace;font-size:.52rem;padding:2px 5px;border-radius:4px;background:var(--card2);border:1px solid var(--border);color:var(--muted);}

.fi{border-radius:2px;vertical-align:middle;margin-right:3px;}



/* Mobile */

@media(max-width:700px){

  .topnav{padding:14px 16px;}

  .controls{padding:8px 12px;}

  .search-box{width:140px;}

  td,th{padding:8px 10px;}

}

@media(max-width:480px){

  .search-box{width:100%;flex:1;min-width:0;}

  .controls{flex-wrap:wrap;gap:6px;}

  .lbl-sm{display:none;}

  .count-lbl{margin-left:0;width:100%;}

  td,th{padding:6px 8px;font-size:.72rem;}

  .cat{display:none;}

  .years-cell{display:none;}

  .venue-city{font-size:.62rem;}

  .count{font-size:.70rem;}

}

</style>

</head>

<body>

<nav class="topnav">
  <a href="index.html" class="topnav-logo">Check-in Journal</a>
  <span class="topnav-current">Venues</span>
  <button class="gs-btn" style="margin-left:auto" onclick="gsOpen()"><span>⌕</span> Search<kbd>⌘K</kbd></button>
</nav>
<div class="gs-overlay" id="gsOverlay" onclick="if(event.target===this)gsClose()">
  <div class="gs-modal"><div class="gs-input-wrap"><span class="gs-icon">⌕</span><input class="gs-input" id="gsInput" type="text" placeholder="Search venues, cities, trips…" autocomplete="off" spellcheck="false"><span class="gs-esc-hint" onclick="gsClose()">esc</span></div></div>
</div>

<div class="controls">

  <span class="lbl-sm">Sort:</span>

  <div class="pill active" id="sort-count" onclick="setSort('count',this)">Most visited</div>

  <div class="pill" id="sort-years" onclick="setSort('years',this)">Years loyal</div>

  <div class="pill" id="sort-name" onclick="setSort('name',this)">A–Z</div>

  <input class="search-box" id="srch" type="text" placeholder="Search venues, cities, categories…" oninput="doSearch(this.value)">

  <span class="count-lbl" id="countLbl"></span>

</div>

<div class="tbl-wrap">

<table>

  <thead>

    <tr>

      <th class="sorted" id="th-count" onclick="setSort('count',null)">#  <span class="sort-ico">▼</span></th>

      <th id="th-name" onclick="setSort('name',null)">Venue <span class="sort-ico">↕</span></th>

      <th id="th-cat">Category</th>

      <th id="th-loc">Location</th>

      <th id="th-years" onclick="setSort('years',null)">Years <span class="sort-ico">↕</span></th>

      <th id="th-ci" onclick="setSort('count',null)">Check-ins <span class="sort-ico">↕</span></th>

    </tr>

  </thead>

  <tbody id="tbody"></tbody>

</table>

</div>

<script>

// [name, city, country, category, count, [years], vid]

const VENUES=VENUES_DATA_PLACEHOLDER;

const ISO2={'Belarus':'by','Russia':'ru','Ukraine':'ua','Georgia':'ge','Moldova':'md','Poland':'pl','Lithuania':'lt','Latvia':'lv','Estonia':'ee','Germany':'de','France':'fr','Italy':'it','Spain':'es','Portugal':'pt','Netherlands':'nl','Belgium':'be','Switzerland':'ch','Austria':'at','Czechia':'cz','Slovakia':'sk','Hungary':'hu','Romania':'ro','Bulgaria':'bg','Serbia':'rs','Croatia':'hr','Slovenia':'si','Greece':'gr','Türkiye':'tr','Turkey':'tr','Armenia':'am','Azerbaijan':'az','Kazakhstan':'kz','Sweden':'se','Denmark':'dk','Norway':'no','Finland':'fi','Malta':'mt','Cyprus':'cy','Luxembourg':'lu','Ireland':'ie','United Kingdom':'gb','Israel':'il','Egypt':'eg','Morocco':'ma','Japan':'jp','China':'cn','India':'in','Thailand':'th','Vietnam':'vn','Indonesia':'id','Singapore':'sg','Malaysia':'my','Philippines':'ph','South Korea':'kr','Uzbekistan':'uz','Iran':'ir','Saudi Arabia':'sa','UAE':'ae','United Arab Emirates':'ae','United States':'us','Canada':'ca','Mexico':'mx','Brazil':'br','Argentina':'ar','Chile':'cl','Colombia':'co','Peru':'pe','Australia':'au','New Zealand':'nz','Holy See (Vatican City State)':'va','North Macedonia':'mk','Bosnia and Herzegovina':'ba','Montenegro':'me','Albania':'al','Andorra':'ad','Monaco':'mc','San Marino':'sm','Liechtenstein':'li','Pakistan':'pk','Bangladesh':'bd','Nepal':'np','Myanmar':'mm','Taiwan':'tw','Hong Kong':'hk','Macao':'mo','Macau':'mo'};

function fi(c){const code=ISO2[c];return code?`<span class="fi fi-${code}"></span>`:'';}

function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}



let sortKey='count', sortDir=1, searchQ='';



function setSort(k, pillEl){

  if(sortKey===k) sortDir*=-1; else {sortKey=k; sortDir=k==='name'?1:-1;}

  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));

  document.querySelectorAll('thead th').forEach(th=>{

    th.classList.remove('sorted');

    const ico=th.querySelector('.sort-ico');

    if(ico) ico.textContent='↕';

  });

  if(pillEl) pillEl.classList.add('active');

  const sortPill=document.getElementById('sort-'+k);

  if(sortPill) sortPill.classList.add('active');

  const sortTh=document.getElementById('th-'+k);

  if(sortTh){sortTh.classList.add('sorted');const ico=sortTh.querySelector('.sort-ico');if(ico)ico.textContent=sortDir>0?'▲':'▼';}

  render();

}



function doSearch(q){searchQ=q.toLowerCase().trim();render();}



function render(){

  let data=[...VENUES];

  if(searchQ) data=data.filter(v=>

    v[0].toLowerCase().includes(searchQ)||

    v[1].toLowerCase().includes(searchQ)||

    v[2].toLowerCase().includes(searchQ)||

    v[3].toLowerCase().includes(searchQ)

  );

  data.sort((a,b)=>{

    if(sortKey==='count') return sortDir*(b[4]-a[4]);

    if(sortKey==='years') return sortDir*(b[5].length-a[5].length)||(b[4]-a[4]);

    return sortDir*a[0].localeCompare(b[0]);

  });



  document.getElementById('countLbl').textContent=`${data.length} venues`;

  const tbody=document.getElementById('tbody');

  if(data.length===0){tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:50px;color:var(--muted)">No venues found</td></tr>';return;}



  // Render all rows

  tbody.innerHTML=data.map((v,i)=>{

    const [name,city,country,cat,count,years,vid]=v;

    const vlink=vid?`<a href="https://foursquare.com/v/${vid}" target="_blank" rel="noopener">${esc(name)}</a>`:esc(name);

    const yrs=years.map(y=>`<span class="yr">${y}</span>`).join('');

    const origRank=i+1;  // rank in current sorted order

    return `<tr>

      <td class="rank">${origRank}</td>

      <td class="venue-name">${vlink}${city?`<div class="venue-city">${fi(country)}${esc(city)}, ${esc(country)}</div>`:''}</td>

      <td><span class="cat">${esc(cat)}</span></td>

      <td>${fi(country)}${esc(city||country)}</td>

      <td class="years-cell"><div class="yr-chips">${yrs}</div></td>

      <td class="count">${count.toLocaleString()}</td>

    </tr>`;

  }).join('');

}



render();
(function(){const _q=new URLSearchParams(location.search).get('q');if(_q){const _inp=document.getElementById('srch');if(_inp){_inp.value=_q;doSearch(_q);}}})();

</script>

<script>
function gsOpen(){document.getElementById('gsOverlay').classList.add('open');document.getElementById('gsInput').focus();}
function gsClose(){document.getElementById('gsOverlay').classList.remove('open');}
document.getElementById('gsInput').addEventListener('keydown',function(e){if(e.key==='Enter'&&this.value.trim()){location.href='search.html?q='+encodeURIComponent(this.value.trim());}if(e.key==='Escape')gsClose();});
document.addEventListener('keydown',function(e){if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();gsOpen();}if(e.key==='Escape'&&document.getElementById('gsOverlay').classList.contains('open'))gsClose();});
</script>

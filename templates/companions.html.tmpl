<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Companions — Check-in Journal</title>
<meta name="description" content="Travel companions ranked by shared check-ins, with country breakdown and yearly social mix analytics. Solo vs together trends over time.">
<link rel="canonical" href="https://4sq.andrei-patsiomkin.workers.dev/companions.html">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Check-in Journal">
<meta property="og:title" content="Companions — Check-in Journal">
<meta property="og:description" content="Travel companions ranked by shared check-ins, with country breakdown and yearly social mix analytics. Solo vs together trends over time.">
<meta property="og:url" content="https://4sq.andrei-patsiomkin.workers.dev/companions.html">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="Companions — Check-in Journal">
<meta name="twitter:description" content="Travel companions ranked by shared check-ins, with country breakdown and yearly social mix analytics. Solo vs together trends over time.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600&family=DM+Mono&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Noto+Color+Emoji&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/6.6.6/css/flag-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;}
.topnav{display:flex;align-items:center;gap:20px;padding:18px 56px;border-bottom:1px solid var(--border);background:var(--card);}
.topnav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--gold);text-decoration:none;}
.topnav a{font-family:'DM Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.14em;color:var(--muted);text-decoration:none;transition:color .2s;}
.topnav a:hover{color:var(--gold);}
.topnav-current{font-family:'DM Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.14em;color:var(--text);}
.topnav a:visited{color:#4a5270;}
.topnav-logo:visited{color:#e8b86d;}
.layout{display:grid;grid-template-columns:260px 1fr;min-height:calc(100vh - 57px);}
.sidebar{border-right:1px solid var(--border);overflow-y:auto;max-height:calc(100vh - 57px);position:sticky;top:0;}
.sidebar::-webkit-scrollbar{width:3px;}
.sidebar::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
.si{display:flex;align-items:center;gap:10px;padding:10px 18px;cursor:pointer;border-left:3px solid transparent;transition:all .15s;}
.si:hover{background:var(--card2);}
.si.active{background:var(--card2);border-left-color:var(--gold);}
.si-name{font-size:0.82rem;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}a.si-name{color:var(--text);text-decoration:none;}a.si-name:hover{color:var(--gold);}
.si-cnt{font-size:0.72rem;font-family:'DM Mono',monospace;color:var(--gold);}
.main{padding:28px 36px;overflow-y:auto;}
.person-name{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--gold);}
.person-meta{font-size:0.78rem;color:var(--muted);margin-top:6px;}
.search-row{display:flex;gap:10px;align-items:center;margin:18px 0;}
.search-box{background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:8px 14px;color:var(--text);font-size:0.82rem;outline:none;width:260px;}
.search-box:focus{border-color:var(--gold);}
.shown-count{font-size:.75rem;color:var(--muted);}
table{width:100%;border-collapse:collapse;}
th{font-size:0.65rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);padding:0 12px 10px;text-align:left;border-bottom:1px solid var(--border);}
td{padding:9px 12px;font-size:0.80rem;border-bottom:1px solid rgba(34,39,56,.45);vertical-align:middle;}
tr:hover td{background:rgba(255,255,255,.02);}
.ci-date{font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--muted);white-space:nowrap;}
.ci-time{font-family:'DM Mono',monospace;font-size:0.67rem;color:var(--muted);opacity:.65;}
.ci-venue a{color:var(--text);text-decoration:none;font-weight:600;}
.ci-venue a:hover{color:var(--gold);}
.ci-cat{font-size:0.68rem;color:var(--teal);text-transform:uppercase;letter-spacing:.04em;margin-top:2px;}
.person-name[href]{text-decoration:none;color:var(--gold);}.person-name[href]:hover{opacity:.8;}.ci-loc{font-size:0.72rem;color:var(--muted);font-family:"Noto Color Emoji","Apple Color Emoji","Segoe UI Emoji",'DM Sans',sans-serif;}
@media(max-width:700px){
  header{padding:16px 16px 12px;}
  .layout{grid-template-columns:1fr;}
  .sidebar{max-height:160px;border-right:none;border-bottom:1px solid var(--border);}
  .main{padding:14px;}
  .search-box{width:100%;max-width:100%;}
  .person-name{font-size:1.6rem;}
  td,th{padding:7px 8px;font-size:.76rem;}
  .ci-date,.ci-time{font-size:.64rem;}
}
@media(max-width:480px){
  .person-name{font-size:1.3rem;}
  table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
  td,th{padding:6px 8px;font-size:.72rem;}
  .ci-loc{display:none;}
}

/* ── SOCIAL ANALYTICS SECTION ── */
.sa-section{padding:32px 40px 72px;}
.sa-section h2{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:900;background:linear-gradient(130deg,#f5d48a 0%,#e8b86d 45%,#b97c30 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:24px;}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:1500px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:26px 30px;position:relative;overflow:hidden;}
.card::after{content:'';position:absolute;top:0;left:24px;right:24px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0.35;}
.card.full{grid-column:1/-1;}
.card-title{font-family:'DM Mono',monospace;font-size:0.62rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--gold);margin-bottom:18px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.card-title em{opacity:0.5;font-style:normal;}
.social-kpi-row{display:flex;gap:10px;margin-bottom:16px;}
.social-kpi{flex:1;background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;}
.social-kpi .sk-num{font-family:'DM Mono',monospace;font-size:1.2rem;}
.social-kpi .sk-lbl{font-size:.58rem;color:var(--muted);margin-top:2px;}
.cc-list{display:flex;flex-direction:column;gap:5px;}
.cc-row{display:grid;grid-template-columns:1fr auto;align-items:center;gap:12px;padding:8px 12px;background:var(--card2);border:1px solid var(--border);border-radius:7px;}
.cc-name{font-size:.78rem;color:var(--text);}
.cc-flags{display:flex;gap:5px;align-items:center;flex-wrap:wrap;justify-content:flex-end;}
@media(max-width:900px){
  .sa-section{padding:20px 16px 48px;}
  .grid{grid-template-columns:1fr;gap:14px;}
  .card{padding:18px 18px;}
  .card.full{grid-column:1;}
  .social-kpi-row{gap:8px;}
  .cc-row{gap:8px;}
}
@media(max-width:520px){
  .social-kpi-row{flex-wrap:wrap;}
  .social-kpi{min-width:calc(50% - 5px);}
  .social-kpi .sk-num{font-size:1rem;}
  .cc-row{grid-template-columns:1fr;gap:5px;}
  .cc-flags{justify-content:flex-start;}
}
</style>
</head>
<body>
<nav class="topnav">
  <a href="index.html" class="topnav-logo">Check-in Journal</a>
  <span class="topnav-current">Companions</span>
  <a href="#social-analytics" style="margin-left:auto;">Social Analytics ↓</a>
</nav>
<h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">Companions</h1>
<div class="layout">
  <div class="sidebar" id="sidebar"></div>
  <div class="main" id="main"></div>
</div>
<script>
const COMP=COMP_DATA_PLACEHOLDER;

const COMPANION_COUNTRIES={'Joanna K.':'Poland','Alex Potemkin':'Belarus','Bojan Bačević':'Serbia','Artemiy Nikitenko':'Belarus','Artemiy Nikitenko (Wellwod)':'Belarus','Tuğba Yoldaş':'Turkey','Тимур -':'Moldova'};

// Country → flag emoji map (inline, no fetch needed)
const F={
  'Albania':'🇦🇱','Andorra':'🇦🇩','Armenia':'🇦🇲','Australia':'🇦🇺','Austria':'🇦🇹',
  'Azerbaijan':'🇦🇿','Bahrain':'🇧🇭','Bangladesh':'🇧🇩','Belarus':'🇧🇾','Belgium':'🇧🇪',
  'Bolivia':'🇧🇴','Bosnia and Herzegovina':'🇧🇦','Brazil':'🇧🇷','Brunei':'🇧🇳',
  'Bulgaria':'🇧🇬','Cambodia':'🇰🇭','Canada':'🇨🇦','Chile':'🇨🇱','China':'🇨🇳',
  'Colombia':'🇨🇴','Costa Rica':'🇨🇷','Croatia':'🇭🇷','Cuba':'🇨🇺','Cyprus':'🇨🇾',
  'Czechia':'🇨🇿','Czech Republic':'🇨🇿','Denmark':'🇩🇰','Ecuador':'🇪🇨','Egypt':'🇪🇬',
  'El Salvador':'🇸🇻','Estonia':'🇪🇪','Ethiopia':'🇪🇹','Finland':'🇫🇮','France':'🇫🇷',
  'Georgia':'🇬🇪','Germany':'🇩🇪','Ghana':'🇬🇭','Greece':'🇬🇷','Guatemala':'🇬🇹',
  'Holy See (Vatican City State)':'🇻🇦','Honduras':'🇭🇳','Hong Kong':'🇭🇰',
  'Hungary':'🇭🇺','Iceland':'🇮🇸','India':'🇮🇳','Indonesia':'🇮🇩','Iran':'🇮🇷',
  'Iraq':'🇮🇶','Ireland':'🇮🇪','Israel':'🇮🇱','Italy':'🇮🇹','Japan':'🇯🇵',
  'Jordan':'🇯🇴','Kazakhstan':'🇰🇿','Kenya':'🇰🇪','Kosovo':'🇽🇰','Kuwait':'🇰🇼',
  'Kyrgyzstan':'🇰🇬','Laos':'🇱🇦','Latvia':'🇱🇻','Lebanon':'🇱🇧','Liechtenstein':'🇱🇮',
  'Lithuania':'🇱🇹','Luxembourg':'🇱🇺','Macao':'🇲🇴','Macau':'🇲🇴','Malaysia':'🇲🇾',
  'Maldives':'🇲🇻','Malta':'🇲🇹','Mexico':'🇲🇽','Moldova':'🇲🇩','Monaco':'🇲🇨',
  'Mongolia':'🇲🇳','Montenegro':'🇲🇪','Morocco':'🇲🇦','Myanmar':'🇲🇲','Nepal':'🇳🇵',
  'Netherlands':'🇳🇱','New Zealand':'🇳🇿','Nigeria':'🇳🇬','North Macedonia':'🇲🇰',
  'Norway':'🇳🇴','Oman':'🇴🇲','Pakistan':'🇵🇰','Panama':'🇵🇦','Paraguay':'🇵🇾',
  'Peru':'🇵🇪','Philippines':'🇵🇭','Poland':'🇵🇱','Portugal':'🇵🇹','Qatar':'🇶🇦',
  'Romania':'🇷🇴','Russia':'🇷🇺','Saudi Arabia':'🇸🇦','Serbia':'🇷🇸','Singapore':'🇸🇬',
  'Slovakia':'🇸🇰','Slovenia':'🇸🇮','South Africa':'🇿🇦','South Korea':'🇰🇷',
  'Spain':'🇪🇸','Sri Lanka':'🇱🇰','Sweden':'🇸🇪','Switzerland':'🇨🇭','Syria':'🇸🇾',
  'Taiwan':'🇹🇼','Tajikistan':'🇹🇯','Tanzania':'🇹🇿','Thailand':'🇹🇭',
  'Türkiye':'🇹🇷','Turkey':'🇹🇷','Turkmenistan':'🇹🇲','Uganda':'🇺🇬','Ukraine':'🇺🇦',
  'United Arab Emirates':'🇦🇪','UAE':'🇦🇪','United Kingdom':'🇬🇧','United States':'🇺🇸',
  'Uruguay':'🇺🇾','Uzbekistan':'🇺🇿','Venezuela':'🇻🇪','Vietnam':'🇻🇳','Zimbabwe':'🇿🇼'
};
function flag(c){return F[c]||'🌍';}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
let cur=0;

const compFlag=COMP.map(c=>{
  if(COMPANION_COUNTRIES[c[0]])return flag(COMPANION_COUNTRIES[c[0]]);
  const ci=c[2]||[];
  for(const r of ci){const country=r[5];if(country)return flag(country);}
  return '🌍';
});
document.getElementById('sidebar').innerHTML=COMP.map((c,i)=>
  `<div class="si" id="si${i}" onclick="show(${i})"><span class="si-flag" style="font-family:'Noto Color Emoji','Apple Color Emoji','Segoe UI Emoji',sans-serif;margin-right:5px">${compFlag[i]}</span>${c[3]?`<a class="si-name" href="https://foursquare.com/user/${c[3]}" target="_blank" rel="noopener" onclick="event.stopPropagation()" title="${esc(c[0])}">${esc(c[0])}</a>`:`<span class="si-name" title="${esc(c[0])}">${esc(c[0])}</span>`}<span class="si-cnt">${c[1].toLocaleString()}</span></div>`
).join('');

function buildRows(ci){
  return ci.map(r=>{
    const [ts,date,time,venue,city,country,cat,vid]=r;
    const loc=[city,country].filter(Boolean);
    const locHtml=loc.length?`${flag(country)} ${esc(loc.join(', '))}`:'';
    const vname=vid?`<a href="https://foursquare.com/v/${vid}" target="_blank" rel="noopener">${esc(venue||'—')}</a>`:esc(venue||'—');
    return `<tr><td><div class="ci-date">${date}</div><div class="ci-time">${time}</div></td>`+
      `<td><div class="ci-venue">${vname}</div><div class="ci-cat">${esc(cat)}</div></td>`+
      `<td class="ci-loc">${locHtml}</td></tr>`;
  }).join('')||'<tr><td colspan="3" style="text-align:center;padding:40px;color:var(--muted)">No results</td></tr>';
}

function filterRows(q){
  const [,,all]=COMP[cur];
  const ql=(q||'').toLowerCase();
  const ci=ql?all.filter(r=>(r[3]||'').toLowerCase().includes(ql)||(r[4]||'').toLowerCase().includes(ql)||(r[5]||'').toLowerCase().includes(ql)||(r[6]||'').toLowerCase().includes(ql)):all;
  const bodyEl=document.getElementById('compBody');
  if(bodyEl)bodyEl.innerHTML=buildRows(ci);
  const shownEl=document.getElementById('compShown');
  if(shownEl)shownEl.textContent=ci.length.toLocaleString()+' shown';
}

function show(idx){
  cur=idx;
  document.querySelectorAll('.si').forEach(e=>e.classList.remove('active'));
  const el=document.getElementById('si'+idx);
  el.classList.add('active');
  el.scrollIntoView({block:'nearest'});
  history.replaceState(null,'','?person='+encodeURIComponent(COMP[idx][0]));
  const [name,count,all,uid]=COMP[cur];
  const cities={};
  all.forEach(r=>{const k=r[4]||(r[5]||'');cities[k]=(cities[k]||0)+1;});
  const top=Object.entries(cities).sort((a,b)=>b[1]-a[1]).slice(0,4).map(([k])=>k).join(' · ');
  document.getElementById('main').innerHTML=`
    ${uid?`<a class="person-name" href="https://foursquare.com/user/${uid}" target="_blank" rel="noopener">${esc(name)}</a>`:`<div class="person-name">${esc(name)}</div>`}
    <div class="person-meta">${count.toLocaleString()} check-ins · ${esc(top)}</div>
    <div class="search-row">
      <input class="search-box" type="text" placeholder="Search venues, cities…" oninput="filterRows(this.value)">
      <span class="shown-count" id="compShown">${all.length.toLocaleString()} shown</span>
    </div>
    <table><thead><tr><th>Date</th><th>Venue</th><th>Location</th></tr></thead>
    <tbody id="compBody">${buildRows(all)}</tbody></table>`;
}
const p=new URLSearchParams(location.search).get('person');
const idx=p?COMP.findIndex(c=>c[0]===p):0;
show(idx>=0?idx:0);
</script>

<!-- ── SOCIAL ANALYTICS ── -->
<div class="sa-section" id="social-analytics">
  <h2>Social Analytics</h2>
  <div class="grid">
    <div class="card">
      <div class="card-title">Solo vs Together</div>
      <div class="social-kpi-row" id="socialKpiRow"></div>
      <canvas id="soloGroupChart" height="200"></canvas>
    </div>

    <div class="card">
      <div class="card-title">Social Mix by Year <em>&middot; solo vs with others</em></div>
      <canvas id="socialYearChart" height="200"></canvas>
    </div>

    <div class="card full">
      <div class="card-title">Companion Countries <em>&middot; top countries visited with each person</em></div>
      <div class="cc-list" id="companionCountriesList"></div>
    </div>
  </div>
</div>

<script>
(function(){
  const SDATA=SOCIAL_STATS_PLACEHOLDER;
  if(!SDATA) return;

  // ISO2 for flag icons
  const ISO2={
    'Afghanistan':'af','Albania':'al','Algeria':'dz','Angola':'ao','Argentina':'ar',
    'Armenia':'am','Australia':'au','Austria':'at','Azerbaijan':'az',
    'Belarus':'by','Belgium':'be','Bolivia':'bo','Bosnia and Herzegovina':'ba',
    'Brazil':'br','Bulgaria':'bg','Cambodia':'kh','Canada':'ca','Chile':'cl',
    'China':'cn','Colombia':'co','Croatia':'hr','Cyprus':'cy','Czech Republic':'cz',
    'Denmark':'dk','Ecuador':'ec','Egypt':'eg','Estonia':'ee','Finland':'fi',
    'France':'fr','Georgia':'ge','Germany':'de','Greece':'gr','Hungary':'hu',
    'Hong Kong':'hk','India':'in','Indonesia':'id','Iran':'ir','Iraq':'iq',
    'Ireland':'ie','Israel':'il','Italy':'it','Japan':'jp','Kazakhstan':'kz',
    'Kosovo':'xk','Kyrgyzstan':'kg','Latvia':'lv','Lithuania':'lt','Luxembourg':'lu',
    'Macao':'mo','Malaysia':'my','Malta':'mt','Mexico':'mx','Moldova':'md',
    'Montenegro':'me','Morocco':'ma','Myanmar':'mm','Netherlands':'nl',
    'New Zealand':'nz','North Macedonia':'mk','Norway':'no','Oman':'om',
    'Pakistan':'pk','Peru':'pe','Philippines':'ph','Poland':'pl','Portugal':'pt',
    'Qatar':'qa','Romania':'ro','Russia':'ru','Serbia':'rs','Singapore':'sg',
    'Slovakia':'sk','Slovenia':'si','South Korea':'kr','Spain':'es','Sweden':'se',
    'Switzerland':'ch','Taiwan':'tw','Thailand':'th','Tunisia':'tn',
    'Turkey':'tr','Türkiye':'tr','Ukraine':'ua','United Arab Emirates':'ae',
    'United Kingdom':'gb','United States':'us','Uruguay':'uy','Uzbekistan':'uz',
    'Venezuela':'ve','Vietnam':'vn','Holy See (Vatican City State)':'va','Vatican City':'va',
    'North Korea':'kp','Cuba':'cu','Iceland':'is','Sri Lanka':'lk','Liechtenstein':'li',
  };
  function flagHtml(country,size){
    const c=(country||'').trim();
    const code=ISO2[c];
    if(!code) return '';
    const sz=size||'1em';
    return `<span class="fi fi-${code}" style="font-size:${sz};border-radius:2px;vertical-align:middle;flex-shrink:0"></span>`;
  }

  Chart.defaults.color='#7a85a8';Chart.defaults.borderColor='#1e2335';
  Chart.defaults.font.family="'DM Mono',monospace";Chart.defaults.font.size=11;

  // ── Social Analytics ──────────────────────────────────────────────────────
  const tot=SDATA.solo_vs_group_totals;
  if(tot&&tot.length){
    const [solo,group]=tot, total=solo+group;
    if(total){
      const kpiRow=document.getElementById('socialKpiRow');
      if(kpiRow) kpiRow.innerHTML=[
        ['Solo check-ins',  solo.toLocaleString(),  'color:var(--gold)'],
        ['With others',     group.toLocaleString(), 'color:var(--teal)'],
        ['Together rate',   (group/total*100).toFixed(1)+'%', 'color:var(--teal)'],
      ].map(([lbl,num,style])=>`<div class="social-kpi"><div class="sk-num" style="${style}">${num}</div><div class="sk-lbl">${lbl}</div></div>`).join('');

      new Chart(document.getElementById('soloGroupChart'),{type:'doughnut',data:{
        labels:['Solo','With others'],
        datasets:[{data:[solo,group],backgroundColor:['rgba(232,184,109,.8)','rgba(78,205,196,.8)'],borderWidth:0,hoverOffset:6}]
      },options:{responsive:true,cutout:'68%',plugins:{legend:{position:'bottom',labels:{font:{size:11},boxWidth:12,padding:10}},tooltip:{callbacks:{label:ctx=>{const v=ctx.parsed;const pct=(v/(solo+group)*100).toFixed(1);return ` ${ctx.label}: ${v.toLocaleString()} (${pct}%)`;}}}}}});

      if(SDATA.solo_vs_group_by_year&&SDATA.solo_vs_group_by_year.length){
        const yrs=SDATA.solo_vs_group_by_year;
        const totals=yrs.map(([,s,g])=>s+g);
        new Chart(document.getElementById('socialYearChart'),{type:'bar',data:{
          labels:yrs.map(d=>d[0]),
          datasets:[
            {label:'Solo',       data:yrs.map(([,s,g],i)=>totals[i]?+(s/totals[i]*100).toFixed(1):0), backgroundColor:'rgba(232,184,109,.75)',borderWidth:0},
            {label:'With others',data:yrs.map(([,s,g],i)=>totals[i]?+(g/totals[i]*100).toFixed(1):0), backgroundColor:'rgba(78,205,196,.75)', borderWidth:0},
          ]
        },options:{responsive:true,plugins:{legend:{position:'bottom',labels:{font:{size:10},boxWidth:10,padding:8}},tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: ${ctx.parsed.y}%`}}},scales:{x:{stacked:true,grid:{display:false}},y:{stacked:true,grid:{color:'#1a1e2e'},ticks:{callback:v=>v+'%'},max:100}}}});
      }
    }
  }

  // ── Companion Countries ───────────────────────────────────────────────────
  const el=document.getElementById('companionCountriesList');
  if(el&&SDATA.companion_countries&&SDATA.companion_countries.length){
    el.innerHTML=SDATA.companion_countries.map(([name,cos])=>{
      const items=cos.map(([co,cnt])=>{
        const f=flagHtml(co,'1.05em');
        return `<span style="display:inline-flex;align-items:center;gap:3px;white-space:nowrap;font-size:.68rem;color:var(--muted)">${f}<span>${esc(co)}</span><span style="font-family:'DM Mono',monospace;color:var(--teal);font-size:.62rem">${cnt}</span></span>`;
      }).join('');
      return `<div class="cc-row" style="grid-template-columns:120px 1fr">
        <div class="cc-name">${esc(name)}</div>
        <div class="cc-flags" style="justify-content:flex-start;gap:8px;flex-wrap:wrap">${items}</div>
      </div>`;
    }).join('');
  }
})();
</script>
</body>
</html>

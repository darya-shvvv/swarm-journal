<script>
(function(){
  var btn=document.getElementById('snThemeToggle');
  var ico=document.getElementById('snThemeIcon');
  var lbl=document.getElementById('snThemeLbl');
  function apply(light){
    document.body.classList.toggle('light',light);
    if(ico) ico.textContent=light?'\u{1F319}':'\u2600\uFE0F';
    if(lbl) lbl.textContent=light?'DARK':'LIGHT';
  }
  apply(localStorage.getItem('fsq-theme')==='light');
  if(btn) btn.addEventListener('click',function(){
    var isLight=document.body.classList.toggle('light');
    localStorage.setItem('fsq-theme',isLight?'light':'dark');
    apply(isLight);
  });
})();
</script>

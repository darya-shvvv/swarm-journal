<style>
:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
body.light{--bg:#ddd8cf;--card:#f0ece3;--card2:#e5e0d7;--border:#aaa49a;--gold:#7a3e00;--teal:#155c58;--muted:#54576a;--text:#15172a;--text2:#373b58;}
body.light header{background:linear-gradient(160deg,#d6d1c8 0%,#dedad1 70%);}
body.light .side-nav{background:rgba(220,215,208,0.97);}
body.light .side-nav a:hover,body.light .side-nav button:hover{background:rgba(0,0,0,.08);}
body.light .heatmap-tooltip,body.light .map-status{background:rgba(220,215,208,0.97);}
body.light .card{box-shadow:0 2px 8px rgba(0,0,0,.10);}
body.light a{color:var(--teal);}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;}
.page{display:flex;flex-direction:column;height:100vh;}

/* в”Җв”Җ Top nav в”Җв”Җ */
.topnav{display:flex;align-items:center;gap:20px;padding:14px 16px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;}
.topnav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--gold);text-decoration:none;margin-right:4px;white-space:nowrap;}
.topnav-logo:hover{opacity:.85;}
.topnav a{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);text-decoration:none;transition:color .2s;}
.topnav a:hover{color:var(--gold);}
.topnav-current{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.14em;color:var(--text);}
.gs-btn{font-family:'DM Mono',monospace;font-size:.60rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);background:var(--card2);border:1px solid var(--border);border-radius:6px;padding:7px 14px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;white-space:nowrap;}
.gs-btn:hover{border-color:var(--gold);color:var(--gold);}
.gs-btn kbd{font-family:'DM Mono',monospace;font-size:.52rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:1px 5px;letter-spacing:0;}
@media(max-width:520px){.gs-btn kbd{display:none;}}
.gs-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:10000;backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding-top:16vh;}.gs-overlay.open{display:flex;}
.gs-modal{background:var(--card);border:1px solid var(--border);border-radius:14px;width:min(560px,92vw);overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.7);}
.gs-input-wrap{display:flex;align-items:center;gap:10px;padding:14px 18px;}
.gs-icon{font-size:1rem;color:var(--muted);}
.gs-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.95rem;}
.gs-input::placeholder{color:var(--muted);}
.gs-esc-hint{font-family:'DM Mono',monospace;font-size:.52rem;color:var(--muted);background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:3px;padding:2px 6px;cursor:pointer;flex-shrink:0;}
.side-nav{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:4000;display:flex;flex-direction:column;gap:0;background:rgba(18,21,31,0.92);border:1px solid var(--border);border-right:none;border-radius:10px 0 0 10px;backdrop-filter:blur(10px);overflow:hidden;}
.side-nav a,.side-nav button{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;width:52px;padding:10px 4px;border:none;background:none;cursor:pointer;color:var(--muted);text-decoration:none;transition:color .15s,background .15s;-webkit-tap-highlight-color:transparent;}
.side-nav a:hover,.side-nav button:hover{background:rgba(255,255,255,.06);color:var(--text);}
.side-nav a.active,.side-nav button.active{color:var(--gold);}
.side-nav .sn-icon{font-size:.95rem;line-height:1;display:inline-block;transition:transform .15s;}
.side-nav a:hover .sn-icon,.side-nav button:hover .sn-icon{transform:scale(1.28);}
.side-nav .sn-lbl{font-family:'DM Mono',monospace;font-size:.42rem;text-transform:uppercase;letter-spacing:.05em;line-height:1;white-space:nowrap;}
.side-nav .sn-sep{width:32px;height:1px;background:var(--border);margin:2px auto;}
.side-nav .sn-sep--pages{width:36px;height:2px;background:var(--border);margin:3px auto;border-radius:1px;}
@media(max-width:900px){.side-nav{display:none;}}

/* в”Җв”Җ Topbar в”Җв”Җ */
.topbar{display:flex;align-items:center;gap:8px;padding:8px 16px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;z-index:200;flex-wrap:wrap;min-height:48px;}
.topbar h1{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:900;background:linear-gradient(130deg,#f5d48a,#e8b86d 50%,#b97c30);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;padding:.05em 0 .12em;display:inline-block;white-space:nowrap;}
.sbtn{background:var(--card2);border:1px solid var(--border);border-radius:7px;color:var(--muted);padding:4px 9px;cursor:pointer;font-size:.70rem;transition:all .12s;font-family:'DM Sans',sans-serif;}
.sbtn:hover{border-color:var(--gold);color:var(--gold);}
.sbtn.act{border-color:var(--gold);color:var(--gold);background:rgba(232,184,109,.08);}
.badge{font-size:.63rem;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap;}
.srch{background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:5px 10px;color:var(--text);font-size:.73rem;outline:none;width:185px;}
.srch:focus{border-color:var(--gold);}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;}

/* в”Җв”Җ Layout в”Җв”Җ */
.content{display:flex;flex:1;overflow:hidden;}
.feed-col{width:400px;flex-shrink:0;overflow:hidden;display:flex;flex-direction:column;border-right:1px solid var(--border);}
.feed-scroll{flex:1;overflow-y:auto;padding:8px;}
.feed-scroll::-webkit-scrollbar{width:3px;}
.feed-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.map-col{flex:1;position:relative;min-width:0;}
#map{position:absolute;inset:0;}
.leaflet-container{background:#0c0e14;}

/* в”Җв”Җ Venue card в”Җв”Җ */
.vcard{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:12px 15px 10px;margin-bottom:7px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden;}
.vcard::after{content:'';position:absolute;top:0;left:16px;right:16px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.2;}
.vcard:hover{border-color:rgba(232,184,109,.35);}
.vcard.sel{border-color:var(--gold);}
.vc-head{display:flex;align-items:flex-start;gap:7px;margin-bottom:6px;}
.vc-cat-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.vc-name{font-size:.87rem;font-weight:700;line-height:1.28;flex:1;}
.vc-name a{color:var(--text);text-decoration:none;}
.vc-name a:hover{color:var(--gold);}
.vc-closed{font-family:'DM Mono',monospace;font-size:.50rem;color:#ef4444;border:1px solid rgba(239,68,68,.45);border-radius:3px;padding:1px 4px;margin-left:5px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.vc-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;}
.vc-loc{font-size:.70rem;color:var(--muted);display:inline-flex;align-items:center;gap:3px;}
.vc-cat{font-family:'DM Mono',monospace;font-size:.54rem;text-transform:uppercase;letter-spacing:.06em;color:var(--teal);white-space:nowrap;}
.vc-date{font-family:'DM Mono',monospace;font-size:.60rem;color:var(--muted);white-space:nowrap;}
.vc-rating{font-size:.85rem;display:inline-block;}
.leaflet-rating-icon{background:none!important;border:none!important;}
.yr-hdr{font-family:'DM Mono',monospace;font-size:.62rem;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);opacity:.7;padding:10px 4px 4px;border-bottom:1px solid var(--border);margin-bottom:6px;}

/* в”Җв”Җ Map popup в”Җв”Җ */
.leaflet-popup-content-wrapper{background:var(--card2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.80rem;}
.leaflet-popup-tip{background:var(--card2);}
.leaflet-popup-content{margin:10px 14px;}

@media(max-width:700px){.feed-col{width:100%;border-right:none;}.map-col{display:none;}}
@media(max-width:480px){
  .topbar{padding:6px 10px;gap:5px;min-height:auto;}
  .topbar h1{font-size:1rem;}
  .srch{width:100%;order:10;margin-top:4px;}
  .tb-right{flex-wrap:wrap;gap:5px;}
  .sbtn{font-size:.64rem;padding:3px 7px;}
  .badge{display:none;}
  .vcard{padding:10px 12px 9px;}
}
</style>
</head>
<body>
<div class="page">
  <nav class="topnav">
    <a href="index.html" class="topnav-logo">Check-in Journal</a>
    <span class="topnav-current">Rated Places</span>
    <button class="gs-btn" style="margin-left:auto" onclick="gsOpen()"><span>вҢ•</span> Search<kbd>вҢҳK</kbd></button>
  </nav>
<div class="gs-overlay" id="gsOverlay" onclick="if(event.target===this)gsClose()">
  <div class="gs-modal"><div class="gs-input-wrap"><span class="gs-icon">вҢ•</span><input class="gs-input" id="gsInput" type="text" placeholder="Search venues, cities, tripsвҖҰ" autocomplete="off" spellcheck="false"><span class="gs-esc-hint" onclick="gsClose()">esc</span></div></div>
</div>
  <div class="topbar">
    <h1>Rated Places</h1>
    <button class="sbtn act" id="fLike"    onclick="setFilter('like',this)"><span>вқӨпёҸ</span> Liked <span id="cntLike" style="opacity:.55;font-size:.65rem;font-family:'DM Mono',monospace;"></span></button>
    <button class="sbtn"     id="fNeutral" onclick="setFilter('neutral',this)"><span style="filter:grayscale(1) brightness(0.55)">рҹҳҗ</span> Neutral <span id="cntNeutral" style="opacity:.55;font-size:.65rem;font-family:'DM Mono',monospace;"></span></button>
    <button class="sbtn"     id="fDislike" onclick="setFilter('dislike',this)"><span style="filter:saturate(0.25) brightness(0.55)">рҹ’”</span> Disliked <span id="cntDislike" style="opacity:.55;font-size:.65rem;font-family:'DM Mono',monospace;"></span></button>
    <button class="sbtn"     id="fClosed"  onclick="toggleClosed(this)">Closed only</button>
    <select class="sbtn" id="fYear" onchange="setYear(this.value)" style="padding:4px 7px;cursor:pointer;"></select>
    <div class="tb-right">
      <input class="srch" id="srch" type="text" placeholder="Search venues, citiesвҖҰ" oninput="onSearch(this.value)">
      <span class="badge" id="badge"></span>
    </div>
  </div>
  <div class="content">
    <div class="feed-col">
      <div class="feed-scroll" id="feedScroll"></div>
    </div>
    <div class="map-col">
      <div id="map"></div>
    </div>
  </div>
</div>


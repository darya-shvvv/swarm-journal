ot':['рҹҘһ','#F39C12'],'Tea Room':['рҹ«–','#27AE60'],'Bubble Tea Shop':['рҹ§Ӣ','#8E44AD'],'Hot Dog Joint':['рҹҢӯ','#E67E22'],'Taco Restaurant':['рҹҢ®','#27AE60'],'Trattoria':['рҹҚқ','#C0392B'],'Deli':['рҹҘӘ','#D4A017'],'Sandwich Spot':['рҹҘӘ','#D4A017'],'Shawarma Restaurant':['рҹҢҜ','#D35400'],'Doner Restaurant':['рҹҢҜ','#E67E22'],'Romanian Restaurant':['рҹҘҳ','#C0392B'],'Polish Restaurant':['рҹҘҹ','#C0392B'],'Modern European Restaurant':['рҹҚҪпёҸ','#C0392B'],'Asian Restaurant':['рҹҘў','#C0392B'],'Noodle Restaurant':['рҹҚң','#E67E22'],'Bagel Shop':['рҹҘҜ','#C8860A'],'Comfort Food Restaurant':['рҹҘҳ','#D4A017'],'Winery':['рҹҚҮ','#922B21'],'Christmas Market':['рҹҺ„','#27AE60']};
function catIcon(cat){const e=CAT_ICON[cat||''];return e?{em:e[0],bg:e[1]}:{em:'рҹ“Қ',bg:'#4a5270'};}

const RATING_EMOJI={'like':'вқӨпёҸ','neutral':'рҹҳҗ','dislike':'рҹ’”'};
const RATING_FILTER={'like':'','neutral':'filter:grayscale(1) brightness(0.55)','dislike':'filter:saturate(0.25) brightness(0.55)'};

function ratingDivIcon(rating,selected){
  const sz=selected?20:14;
  const filt=RATING_FILTER[rating]||'';
  return L.divIcon({
    html:'<span style="font-size:'+sz+'px;line-height:1;display:block;'+filt+'">'+RATING_EMOJI[rating]+'</span>',
    className:'leaflet-rating-icon',
    iconSize:[sz+2,sz+2],
    iconAnchor:[(sz+2)/2,(sz+2)/2],
  });
}

// в”Җв”Җ Map в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const map=L.map('map',{preferCanvas:true}).setView([30,15],2);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);

const markers={};
let selMarker=null,selIdx=-1;
ALL.forEach((v,i)=>{
  if(!v.lat||!v.lng)return;
  const m=L.marker([parseFloat(v.lat),parseFloat(v.lng)],{icon:ratingDivIcon(v.rating,false)}).addTo(map);
  const loc=[v.nci||v.city,v.nc||v.country].filter(Boolean).join(', ');
  m.bindPopup(`<b>${esc(v.name||'')}</b><br><span style="font-size:.75rem;color:#9ca3af;">${esc(loc)}</span><br><span style="font-size:.78rem;">${RATING_EMOJI[v.rating]||''} ${esc(v.category||'')}</span>`,{maxWidth:220});
  markers[i]=m;
});

// в”Җв”Җ Filter state в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let filterRating='like', query='', showClosed=false, yearFilter=0;

// Populate year select (by first-visit year)
(function(){
  const yearsSet=new Set();
  ALL.forEach(v=>{if(v.created_at)yearsSet.add(new Date(v.created_at*1000).getFullYear());});
  const sel=document.getElementById('fYear');
  const defOpt=document.createElement('option');
  defOpt.value='0';defOpt.textContent='All years';sel.appendChild(defOpt);
  [...yearsSet].sort((a,b)=>b-a).forEach(y=>{
    const o=document.createElement('option');o.value=y;o.textContent=y;sel.appendChild(o);
  });
})();
function fmtDate(ts){if(!ts)return'';const d=new Date(ts*1000);return d.getDate().toString().padStart(2,'0')+' '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getFullYear();}

// Update button counts
document.getElementById('cntLike').textContent   = COUNTS.likes    ? '('+COUNTS.likes+')'    : '';
document.getElementById('cntNeutral').textContent = COUNTS.neutral  ? '('+COUNTS.neutral+')'  : '';
document.getElementById('cntDislike').textContent = COUNTS.dislikes ? '('+COUNTS.dislikes+')' : '';

function getFiltered(){
  const q=query.toLowerCase();
  return ALL.map((_,i)=>i).filter(i=>{
    const v=ALL[i];
    if(v.rating!==filterRating)return false;
    if(showClosed&&!v.closed)return false;
    if(yearFilter&&(!v.created_at||new Date(v.created_at*1000).getFullYear()!==yearFilter))return false;
    if(!q)return true;
    return (v.name||'').toLowerCase().includes(q)||(v.city||'').toLowerCase().includes(q)||(v.country||'').toLowerCase().includes(q)||(v.category||'').toLowerCase().includes(q);
  });
}

function render(){
  const idx=getFiltered();
  // rate_idx = exact web list position (scraped from foursquare.com/list/venuelikes)
  idx.sort((a,b)=>ALL[a].rate_idx-ALL[b].rate_idx);
  document.getElementById('badge').textContent=idx.length+' / '+ALL.filter(v=>v.rating===filterRating).length+' venues';
  let prevYear=null;
  document.getElementById('feedScroll').innerHTML=idx.map(i=>{
    const v=ALL[i];
    const{em,bg}=catIcon(v.category||'');
    const vUrl=v.url||'';
    const loc=[v.nci||v.city,v.nc||v.country].filter(Boolean).join(', ');
    const f=(v.nc||v.country)?flagHtml(v.nc||v.country):'';
    const closedBadge=v.closed?'<span class="vc-closed">CLOSED</span>':'';
    const venueLabel=vUrl?`<a href="${vUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(v.name||'Unknown venue')}</a>`:esc(v.name||'Unknown venue');
    const yr=v.created_at?new Date(v.created_at*1000).getFullYear():null;
    let hdr='';
    if(yr&&yr!==prevYear){hdr=`<div class="yr-hdr">${yr}</div>`;prevYear=yr;}
    return hdr+`<div class="vcard" id="vc_${i}" onclick="selectVenue(${i})">
      <div class="vc-head">
        <div class="vc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
        <div class="vc-name">${venueLabel}${closedBadge}</div>
        <span class="vc-rating"${RATING_FILTER[v.rating]?' style="'+RATING_FILTER[v.rating]+'"':''}>${RATING_EMOJI[v.rating]||''}</span>
      </div>
      <div class="vc-foot">
        <span class="vc-cat">${esc(v.category||'')}</span>
        <span class="vc-loc">${f}${esc(loc)}</span>
        <span class="vc-date">${fmtDate(v.created_at)||''}</span>
      </div>
    </div>`;
  }).join('');
}

function selectVenue(i){
  if(selMarker&&selIdx>=0)selMarker.setIcon(ratingDivIcon(ALL[selIdx].rating,false));
  document.querySelectorAll('.vcard.sel').forEach(el=>el.classList.remove('sel'));
  const el=document.getElementById('vc_'+i);
  if(el){el.classList.add('sel');el.scrollIntoView({block:'nearest',behavior:'smooth'});}
  const m=markers[i];
  if(m){
    m.setIcon(ratingDivIcon(ALL[i].rating,true));
    selMarker=m;selIdx=i;
    map.panTo(m.getLatLng(),{animate:true});
    m.openPopup();
  }
}

function setFilter(r,btn){
  filterRating=r;
  document.querySelectorAll('.sbtn:not(#fClosed)').forEach(b=>b.classList.remove('act'));
  btn.classList.add('act');
  render();
}
function toggleClosed(btn){showClosed=!showClosed;btn.classList.toggle('act');render();}
function onSearch(v){query=v;render();}
function setYear(v){yearFilter=parseInt(v)||0;render();}

render();

(function(){const _q=new URLSearchParams(location.search).get('q');if(_q){const _inp=document.getElementById('srch');if(_inp){_inp.value=_q;onSearch(_q);}}})();
</script>
<script>
function gsOpen(){document.getElementById('gsOverlay').classList.add('open');document.getElementById('gsInput').focus();}
function gsClose(){document.getElementById('gsOverlay').classList.remove('open');}
document.getElementById('gsInput').addEventListener('keydown',function(e){if(e.key==='Enter'&&this.value.trim()){location.href='search.html?q='+encodeURIComponent(this.value.trim());}if(e.key==='Escape')gsClose();});
document.addEventListener('keydown',function(e){if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();gsOpen();}if(e.key==='Escape'&&document.getElementById('gsOverlay').classList.contains('open'))gsClose();});
</script>
